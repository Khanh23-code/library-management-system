<UserControl x:Class="THUVIENZ.Views.AdminBorrowing"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:comp="clr-namespace:THUVIENZ.Views.Components">

    <UserControl.Resources>
        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F9FAFB"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#F3F4F6"/>
            <Setter Property="Padding" Value="0,10"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EFF6FF"/>
                    <Setter Property="Foreground" Value="#1D4ED8"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F3F4F6"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border Background="White" CornerRadius="35"
                HorizontalAlignment="Center" VerticalAlignment="Center" 
                Width="1250" Height="700">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Opacity="0.2" ShadowDepth="10" Color="Black"/>
            </Border.Effect>

            <Grid Margin="50,40,50,40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Quản lý Mượn / Trả" FontSize="36" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Theo dõi trạng thái sách đang được mượn và ghi nhận trả sách" FontSize="16" Foreground="#6B7280" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
                    <Border Background="#EFF6FF" BorderBrush="#3B82F6" BorderThickness="0,0,0,2" Padding="20,10" Margin="0,0,10,0" Cursor="Hand">
                        <TextBlock Text="Đang mượn (Hiện tại)" FontSize="16" FontWeight="Bold" Foreground="#1D4ED8"/>
                    </Border>
                    <Border Background="Transparent" BorderBrush="Transparent" BorderThickness="0,0,0,2" Padding="20,10" Cursor="Hand">
                        <TextBlock Text="Lịch sử (Đã xong)" FontSize="16" FontWeight="SemiBold" Foreground="#6B7280"/>
                    </Border>
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3.5*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="6.5*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#F9FAFB" CornerRadius="20" BorderBrush="#E5E7EB" BorderThickness="1">
                        <Grid Margin="15">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <comp:SearchBar Grid.Row="0" Margin="0,0,0,15"/>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <DataGrid x:Name="dgReaders" ItemsSource="{Binding ReadersList}" SelectedItem="{Binding SelectedReader}" Style="{StaticResource ModernDataGrid}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Mã ĐG" Binding="{Binding MaDocGia}" Width="80"/>
                                        <DataGridTextColumn Header="Tên Độc Giả" Binding="{Binding HoTen}" Width="*"/>
                                        <DataGridTextColumn Header="S.Lượng" Binding="{Binding BorrowCount}" Width="80"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Background="White" CornerRadius="20" BorderBrush="#E5E7EB" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" Opacity="0.05" ShadowDepth="2"/>
                        </Border.Effect>

                        <Grid Margin="25">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="Chi tiết Giao dịch Mượn / Trả" FontSize="20" FontWeight="Bold" Foreground="#111827"/>
                                    <TextBlock x:Name="txtSelectedReader" Text="{Binding SelectedReader.HoTen, TargetNullValue='Vui lòng chọn một độc giả...'}" FontSize="16" Foreground="#4285F4" FontWeight="SemiBold" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Grid>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <DataGrid x:Name="dgBooks" ItemsSource="{Binding BorrowedBooks}" Style="{StaticResource ModernDataGrid}">
                                    <DataGrid.Columns>
                                        <!-- Cột 1: Thông tin sách và mã vật lý -->
                                        <DataGridTemplateColumn Header="Sách &amp; Mã" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel VerticalAlignment="Center" Margin="5,8">
                                                        <TextBlock Text="{Binding TenSach}" FontSize="14" FontWeight="SemiBold" Foreground="#111827" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                                        <Border Background="#F3F4F6" CornerRadius="6" Padding="6,2" HorizontalAlignment="Left">
                                                            <TextBlock Text="{Binding MaCuonSach, StringFormat='Mã vật lý: CS-{0}'}" FontSize="11" FontWeight="Medium" Foreground="#6B7280"/>
                                                        </Border>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- Cột 2: Thời hạn Mượn và Hạn trả -->
                                        <DataGridTemplateColumn Header="Thời Hạn" Width="150">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel VerticalAlignment="Center" Margin="5,8">
                                                        <TextBlock FontSize="12" Foreground="#6B7280" Margin="0,0,0,4">
                                                            <Run Text="Mượn: "/>
                                                            <Run Text="{Binding NgayMuon, StringFormat=dd/MM/yyyy}" FontWeight="Medium" Foreground="#374151"/>
                                                        </TextBlock>
                                                        <TextBlock FontSize="12" Foreground="#D97706" FontWeight="SemiBold">
                                                            <Run Text="Hạn trả: "/>
                                                            <Run Text="{Binding HanTra, StringFormat=dd/MM/yyyy}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- Cột 3: Trạng thái thực tế và Tiền phạt -->
                                        <DataGridTemplateColumn Header="Thực Tế &amp; Phạt" Width="150">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel VerticalAlignment="Center" Margin="5,8">
                                                        <ContentControl Content="{Binding NgayTra}">
                                                            <ContentControl.Style>
                                                                <Style TargetType="ContentControl">
                                                                    <Setter Property="ContentTemplate">
                                                                        <Setter.Value>
                                                                            <DataTemplate>
                                                                                <TextBlock Text="{Binding StringFormat='Đã trả: {0:dd/MM/yyyy}'}" FontSize="12" FontWeight="SemiBold" Foreground="#10B981" Margin="0,0,0,4"/>
                                                                            </DataTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                    <Style.Triggers>
                                                                        <Trigger Property="Content" Value="{x:Null}">
                                                                            <Setter Property="ContentTemplate">
                                                                                <Setter.Value>
                                                                                    <DataTemplate>
                                                                                        <TextBlock Text="⏳ Chưa hoàn trả" FontSize="12" FontWeight="SemiBold" Foreground="#EF4444" Margin="0,0,0,4"/>
                                                                                    </DataTemplate>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ContentControl.Style>
                                                        </ContentControl>
                                                        
                                                        <TextBlock Text="{Binding TienPhat, StringFormat='Phạt: {0:N0} đ'}" FontSize="12" FontWeight="Bold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#EF4444"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding TienPhat}" Value="0">
                                                                            <Setter Property="Foreground" Value="#9CA3AF"/>
                                                                            <Setter Property="FontWeight" Value="Normal"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- Cột 4: Thao tác nhận trả tuyệt đối không khuyết -->
                                        <DataGridTemplateColumn Header="Thao Tác" Width="115">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="{Binding ActionText}" IsEnabled="{Binding IsActionEnabled}" 
                                                            Command="{Binding DataContext.ReturnBookCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                            CommandParameter="{Binding}" FontWeight="Bold" FontSize="13" BorderThickness="0" Cursor="Hand"
                                                            Width="85" Height="32" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Background" Value="#10B981"/>
                                                                <Setter Property="Foreground" Value="White"/>
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsEnabled" Value="False">
                                                                        <Setter Property="Background" Value="#E5E7EB"/>
                                                                        <Setter Property="Foreground" Value="#9CA3AF"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#059669"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>