<UserControl x:Class="THUVIENZ.Views.Notifications"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:comp="clr-namespace:THUVIENZ.Views.Components"
             Loaded="UserControl_Loaded">

    <Grid>
        <Border Background="White" CornerRadius="35"
            HorizontalAlignment="Center" VerticalAlignment="Center" 
            Width="900" Height="620">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Opacity="0.2" ShadowDepth="10" Color="Black"/>
            </Border.Effect>

            <Grid Margin="60,50,60,50">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,30">
                    <TextBlock Text="Thông báo" FontSize="36" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Các thông báo quan trọng của bạn" FontSize="16" Foreground="#6B7280" Margin="0,5,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="NotificationContainer">
                        <comp:NotificationCard NotiType="Success" Message="Chào mừng độc giả Khang! Tài khoản Librix của bạn đã được kích hoạt thành công." Timestamp="Vừa xong" OnCloseRequested="NotificationCard_OnCloseRequested"/>
                        <comp:NotificationCard NotiType="Warning" Message="Cảnh báo: Cuốn sách 'Clean Code' của bạn còn 3 ngày nữa là hết hạn trả." Timestamp="2 giờ trước" OnCloseRequested="NotificationCard_OnCloseRequested"/>
                        <comp:NotificationCard NotiType="Failure" Message="Gia hạn thất bại: Hệ thống không thể xử lý yêu cầu gia hạn cuốn 'Nhà Giả Kim'. Vui lòng thử lại." Timestamp="1 ngày trước" OnCloseRequested="NotificationCard_OnCloseRequested"/>
                        <comp:NotificationCard NotiType="Info" Message="Thông báo: Thư viện Librix cập nhật khung phạt mới đối với các đầu sách hư hại kể từ ngày 20/05." Timestamp="3 ngày trước" OnCloseRequested="NotificationCard_OnCloseRequested"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>