<UserControl x:Class="THUVIENZ.Views.Notifications"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:comp="clr-namespace:THUVIENZ.Views.Components"
             xmlns:pop="clr-namespace:THUVIENZ.Views.Popups"
             Loaded="UserControl_Loaded">

    <Grid>

        <Border Background="White" CornerRadius="35"
                HorizontalAlignment="Center" VerticalAlignment="Center" 
                Width="900" Height="620">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Opacity="0.2" ShadowDepth="10" Color="Black"/>
            </Border.Effect>

            <Grid Margin="60,50,60,50">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,30">
                    <TextBlock Text="Thông báo" FontSize="36" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Các thông báo quan trọng của bạn" FontSize="16" Foreground="#6B7280" Margin="0,5,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="NotificationContainer" Margin="0,0,10,0">
                        <comp:NotificationCard NotiType="Success" 
                                               Title="Kích hoạt thành công" 
                                               Message="Chào mừng độc giả Khang! Tài khoản Librix của bạn đã được kích hoạt thành công. Hãy bắt đầu khám phá hàng ngàn cuốn sách ngay hôm nay." 
                                               Timestamp="Vừa xong" 
                                               OnCloseRequested="NotificationCard_OnCloseRequested" 
                                               OnCardClicked="NotificationCard_OnCardClicked"/>

                        <comp:NotificationCard NotiType="Warning" 
                                               Title="Sách sắp hết hạn" 
                                               Message="Cảnh báo: Cuốn sách 'Clean Code' của bạn còn 3 ngày nữa là hết hạn trả. Vui lòng gia hạn hoặc trả sách đúng hạn để tránh phát sinh phí phạt." 
                                               Timestamp="2 giờ trước" 
                                               OnCloseRequested="NotificationCard_OnCloseRequested" 
                                               OnCardClicked="NotificationCard_OnCardClicked"/>

                        <comp:NotificationCard NotiType="Failure" 
                                               Title="Gia hạn thất bại" 
                                               Message="Gia hạn thất bại: Hệ thống không thể xử lý yêu cầu gia hạn cuốn 'Nhà Giả Kim'. Vui lòng kiểm tra lại kết nối mạng hoặc liên hệ thủ thư." 
                                               Timestamp="1 ngày trước" 
                                               OnCloseRequested="NotificationCard_OnCloseRequested" 
                                               OnCardClicked="NotificationCard_OnCardClicked"/>

                        <comp:NotificationCard NotiType="Info" 
                                               Title="Cập nhật quy định mới" 
                                               Message="Thông báo: Thư viện Librix cập nhật khung phạt mới đối với các đầu sách hư hại hoặc làm mất kể từ ngày 20/05. Chi tiết vui lòng xem tại bảng tin." 
                                               Timestamp="3 ngày trước" 
                                               OnCloseRequested="NotificationCard_OnCloseRequested" 
                                               OnCardClicked="NotificationCard_OnCardClicked"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <pop:NotificationDetailPopup x:Name="DetailPopup" Panel.ZIndex="100"/>
    </Grid>
</UserControl>