<UserControl x:Class="THUVIENZ.Views.Notifications"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:comp="clr-namespace:THUVIENZ.Views.Components"
             xmlns:pop="clr-namespace:THUVIENZ.Views.Popups"
             Loaded="UserControl_Loaded">

    <Grid>

        <Border Background="White" CornerRadius="35"
                HorizontalAlignment="Center" VerticalAlignment="Center" 
                Width="900" Height="620">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Opacity="0.2" ShadowDepth="10" Color="Black"/>
            </Border.Effect>

            <Grid Margin="60,50,60,50">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,30">
                    <TextBlock Text="Thông báo" FontSize="36" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Các thông báo quan trọng của bạn" FontSize="16" Foreground="#6B7280" Margin="0,5,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="NotificationContainer" Margin="0,0,10,0">
                        <!-- Dynamic notification cards will be loaded here -->
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <pop:NotificationDetailPopup x:Name="DetailPopup" Panel.ZIndex="100"/>
    </Grid>
</UserControl>