<UserControl x:Class="THUVIENZ.Views.Profile"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:THUVIENZ">

    <Grid>

        <Border Background="White" CornerRadius="35"
            HorizontalAlignment="Center" VerticalAlignment="Center" 
                Width="900" Height="620">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Opacity="0.2" ShadowDepth="10" Color="Black"/>
            </Border.Effect>

            <Grid Margin="60,50,60,50">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,40">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Thông tin độc giả" FontSize="36" FontWeight="Bold" Foreground="#111827"/>
                        <TextBlock Text="Quản lý thông tin cá nhân và liên hệ của bạn" FontSize="16" Foreground="#6B7280" Margin="0,5,0,0"/>
                    </StackPanel>

                    <Ellipse HorizontalAlignment="Right" Width="90" Height="90" Stroke="#E5E7EB" StrokeThickness="3">
                        <Ellipse.Effect>
                            <DropShadowEffect BlurRadius="15" Opacity="0.2" ShadowDepth="5"/>
                        </Ellipse.Effect>
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="/Assets/phai.png" Stretch="UniformToFill"/>
                        </Ellipse.Fill>
                    </Ellipse>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Họ và Tên" FontSize="16" FontWeight="SemiBold" Foreground="#555" Margin="10,0,0,8"/>
                        <Border Background="#F3F4F6" CornerRadius="12" Height="60" Margin="0,0,0,30" BorderBrush="#E5E7EB" BorderThickness="2">
                            <TextBox Text="Nguyễn Văn Reader" Background="Transparent" BorderThickness="0" FontSize="18" VerticalContentAlignment="Center" Padding="15,0" Foreground="Black"/>
                        </Border>

                        <TextBlock Text="Mã Độc Giả (Reader ID)" FontSize="16" FontWeight="SemiBold" Foreground="#555" Margin="10,0,0,8"/>
                        <Border Background="#F3F4F6" CornerRadius="12" Height="60" Margin="0,0,0,30" BorderBrush="#E5E7EB" BorderThickness="2">
                            <TextBox Text="RD-2023" Background="Transparent" BorderThickness="0" FontSize="18" VerticalContentAlignment="Center" Padding="15,0" Foreground="#888" IsReadOnly="True"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Số điện thoại" FontSize="16" FontWeight="SemiBold" Foreground="#555" Margin="10,0,0,8"/>
                        <Border Background="#F3F4F6" CornerRadius="12" Height="60" Margin="0,0,0,30" BorderBrush="#E5E7EB" BorderThickness="2">
                            <TextBox Text="0909123456" Background="Transparent" BorderThickness="0" FontSize="18" VerticalContentAlignment="Center" Padding="15,0" Foreground="Black"/>
                        </Border>

                        <TextBlock Text="Địa chỉ liên hệ" FontSize="16" FontWeight="SemiBold" Foreground="#555" Margin="10,0,0,8"/>
                        <Border Background="#F3F4F6" CornerRadius="12" Height="60" Margin="0,0,0,30" BorderBrush="#E5E7EB" BorderThickness="2">
                            <TextBox Text="Bình Dương" Background="Transparent" BorderThickness="0" FontSize="18" VerticalContentAlignment="Center" Padding="15,0" Foreground="Black"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <Button Grid.Row="2" Content="Lưu Thay Đổi" Foreground="White" FontSize="20" FontWeight="Bold" Width="220" Height="60" Cursor="Hand" HorizontalAlignment="Right">
                    <Button.Style>
                        <Style TargetType="{x:Type Button}">
                            <Setter Property="Background" Value="#00E676"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type Button}">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="30">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.3" Color="Black" Direction="270"/>
                                            </Border.Effect>
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#00C853"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>