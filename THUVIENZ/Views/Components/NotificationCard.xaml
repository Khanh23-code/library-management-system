<UserControl x:Class="THUVIENZ.Views.Components.NotificationCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:local="clr-namespace:THUVIENZ.Views.Components"
             x:Name="root" Margin="0,0,0,12">

    <UserControl.Template>
        <ControlTemplate TargetType="local:NotificationCard">

            <Border x:Name="CardBorder" CornerRadius="16" BorderThickness="1.5" Padding="16" Background="White">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.05" ShadowDepth="2" Color="Black"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border x:Name="IconContainer" Grid.Column="0" Width="40" Height="40" CornerRadius="20" Margin="0,0,16,0">
                        <fa:IconImage x:Name="IconVisual" Width="20" Height="20"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{TemplateBinding Message}" 
                                   FontSize="15" Foreground="#111827" TextWrapping="Wrap" FontWeight="Medium"/>
                        <TextBlock Text="{TemplateBinding Timestamp}" 
                                   FontSize="12" Foreground="#9CA3AF" Margin="0,4,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="2" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnDelete_Click">
                        <fa:IconImage Icon="Times" Width="14" Height="14" Foreground="#9CA3AF"/>
                    </Button>
                </Grid>
            </Border>

            <ControlTemplate.Triggers>
                <Trigger Property="NotiType" Value="Success">
                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="#D1FAE5"/>
                    <Setter TargetName="IconContainer" Property="Background" Value="#E6F4EA"/>
                    <Setter TargetName="IconVisual" Property="Icon" Value="CheckCircle"/>
                    <Setter TargetName="IconVisual" Property="Foreground" Value="#137333"/>
                </Trigger>

                <Trigger Property="NotiType" Value="Failure">
                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="#FEE2E2"/>
                    <Setter TargetName="IconContainer" Property="Background" Value="#FCE8E6"/>
                    <Setter TargetName="IconVisual" Property="Icon" Value="TimesCircle"/>
                    <Setter TargetName="IconVisual" Property="Foreground" Value="#C5221F"/>
                </Trigger>

                <Trigger Property="NotiType" Value="Warning">
                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="#FEF3C7"/>
                    <Setter TargetName="IconContainer" Property="Background" Value="#FEF7E0"/>
                    <Setter TargetName="IconVisual" Property="Icon" Value="ExclamationTriangle"/>
                    <Setter TargetName="IconVisual" Property="Foreground" Value="#B06000"/>
                </Trigger>

                <Trigger Property="NotiType" Value="Info">
                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="#DBEAFE"/>
                    <Setter TargetName="IconContainer" Property="Background" Value="#E8F0FE"/>
                    <Setter TargetName="IconVisual" Property="Icon" Value="InfoCircle"/>
                    <Setter TargetName="IconVisual" Property="Foreground" Value="#1A73E8"/>
                </Trigger>
            </ControlTemplate.Triggers>

        </ControlTemplate>
    </UserControl.Template>
</UserControl>