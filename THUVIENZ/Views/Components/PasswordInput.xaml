<UserControl x:Class="THUVIENZ.UserControls.PasswordInput"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             x:Name="root">

    <Border Background="#F3F4F6" CornerRadius="12" Height="55" Margin="0,0,0,0" BorderBrush="#E5E7EB" BorderThickness="2" x:Name="MainBorder">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="50"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="lblPlaceholder"
                       Text="{Binding ElementName=root, Path=Placeholder}" 
                       Foreground="#A0A0A0" 
                       FontSize="18" 
                       VerticalAlignment="Center" 
                       Margin="18,0,0,0"
                       IsHitTestVisible="False"/>

            <PasswordBox x:Name="txtPassword"
                         Grid.Column="0"
                         Background="Transparent" 
                         BorderThickness="0" 
                         FontSize="18" 
                         VerticalContentAlignment="Center" 
                         Padding="15,0" 
                         Foreground="Black"
                         PasswordChanged="txtPassword_PasswordChanged"/>

            <TextBox x:Name="txtPasswordVisible"
                     Grid.Column="0"
                     Background="Transparent" 
                     BorderThickness="0" 
                     FontSize="18" 
                     VerticalContentAlignment="Center" 
                     Padding="15,0" 
                     Foreground="Black"
                     Visibility="Collapsed"
                     TextChanged="txtPasswordVisible_TextChanged"/>

            <Button x:Name="btnShowPassword"
            Grid.Column="1"
            Background="Transparent"
            BorderThickness="0"
            Cursor="Hand"
            Click="btnShowPassword_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <fa:IconImage x:Name="iconPassword" 
                                      Icon="Eye" 
                                      Width="20" Height="20" 
                                      Foreground="#A0A0A0"/>
                                    </Border>

                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="iconPassword" Property="Foreground" Value="#4285F4"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>

                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Border>
</UserControl>