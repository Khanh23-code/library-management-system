<UserControl x:Class="THUVIENZ.Views.Components.BookCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="320" Height="220" Margin="10,10,20,20">
    <UserControl.Resources>
        <Style x:Key="CardBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" BorderThickness="1" BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="#F9FAFB" CornerRadius="25">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.1" ShadowDepth="5" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="15" Margin="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.2" ShadowDepth="3"/>
                </Border.Effect>
                <Border.Background>
                    <ImageBrush ImageSource="{Binding CoverImage, RelativeSource={RelativeSource AncestorType=UserControl}}" Stretch="UniformToFill"/>
                </Border.Background>
            </Border>

            <Grid Grid.Column="1" Margin="0,20,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="{Binding BookTitle, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                               FontSize="22" FontWeight="Bold" Foreground="#111827" TextTrimming="CharacterEllipsis"/>

                    <TextBlock FontSize="15" Foreground="#6B7280" Margin="0,2,0,0">
                        <Run Text="Author: "/>
                        <Run Text="{Binding Author, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    </TextBlock>

                    <TextBlock FontSize="14" Foreground="#9CA3AF" Margin="0,2,0,0">
                        <Run Text="Book ID: "/>
                        <Run Text="{Binding BookId, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    </TextBlock>
                </StackPanel>

                <TextBlock Grid.Row="1" FontSize="20" FontWeight="Bold" Foreground="#00C853" VerticalAlignment="Center">
                    <Run Text="Giá: "/>
                    <Run Text="{Binding Price, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                </TextBlock>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="❤" FontSize="18" Foreground="#FF4C4C" Background="#FEE2E2" BorderBrush="Transparent" Width="40" Height="40" Margin="0,0,10,0" Style="{StaticResource CardBtn}" ToolTip="Bỏ yêu thích"/>
                    <Button Content="Mượn ngay" FontSize="14" Foreground="White" Background="#4285F4" BorderBrush="Transparent" Width="100" Height="40" Style="{StaticResource CardBtn}">
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)" To="#2B6CB0" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)" To="#4285F4" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>