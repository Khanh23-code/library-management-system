<UserControl x:Class="THUVIENZ.Views.Components.ReaderCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="350" Height="200" Margin="0,0,20,20">
    <Border Background="White" CornerRadius="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.15" ShadowDepth="5" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="15" Margin="15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.2" ShadowDepth="3"/>
                </Border.Effect>
                <Border.Background>
                    <ImageBrush ImageSource="{Binding AvatarSource, RelativeSource={RelativeSource AncestorType=UserControl}}" Stretch="UniformToFill"/>
                </Border.Background>
            </Border>

            <Grid Grid.Column="1" Margin="0,15,10,15">
                <StackPanel VerticalAlignment="Center">

                    <TextBlock FontSize="14" Foreground="#374151" Margin="0,0,0,5" TextTrimming="CharacterEllipsis">
                        <Run Text="Tên: " FontWeight="SemiBold"/>
                        <Run Text="{Binding ReaderName, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    </TextBlock>

                    <TextBlock FontSize="13" Foreground="#4B5563" Margin="0,0,0,5" TextTrimming="CharacterEllipsis">
                        <Run Text="Địa chỉ: " FontWeight="SemiBold"/>
                        <Run Text="{Binding Address, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    </TextBlock>

                    <TextBlock FontSize="13" Foreground="#4B5563" Margin="0,0,0,5" TextTrimming="CharacterEllipsis">
                        <Run Text="ID: " FontWeight="SemiBold"/>
                        <Run Text="{Binding ReaderId, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    </TextBlock>

                    <TextBlock FontSize="13" Foreground="#4B5563" Margin="0,0,0,5" TextTrimming="CharacterEllipsis">
                        <Run Text="Giới tính: " FontWeight="SemiBold"/>
                        <Run Text="{Binding Gender, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    </TextBlock>

                    <TextBlock FontSize="13" Foreground="#4B5563" Margin="0,0,0,5" TextTrimming="CharacterEllipsis">
                        <Run Text="Email: " FontWeight="SemiBold"/>
                        <Run Text="{Binding Email, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    </TextBlock>

                    <TextBlock FontSize="13" Foreground="#4B5563" TextTrimming="CharacterEllipsis">
                        <Run Text="SĐT: " FontWeight="SemiBold"/>
                        <Run Text="{Binding Phone, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    </TextBlock>

                </StackPanel>
            </Grid>

            <Button Grid.Column="1" Content="XÓA" Background="#EF4444" Foreground="White" 
                    FontWeight="Bold" FontSize="11" Cursor="Hand"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom" 
                    Width="70" Height="25" Margin="0,0,10,10"
                    Click="BtnDelete_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#DC2626"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

        </Grid>
    </Border>
</UserControl>