<UserControl x:Class="THUVIENZ.Views.Components.AdminNavigationBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp">

    <UserControl.Resources>
        <Style x:Key="MenuBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="25,15"/>
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30FFFFFF"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Height="620" Margin="40,0,0,0" CornerRadius="35" Background="#60000000">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="5" Color="Black"/>
        </Border.Effect>
        <StackPanel Margin="0,40,0,10">
            <TextBlock Text="⚙️ Admin" FontSize="36" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,60"/>

            <Button Click="BtnBooks_Click">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <fa:IconImage Icon="Book" 
                                      Width="22" Height="22" Margin="0,0,15,0"
                                      Foreground="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>

                        <TextBlock Text="Quản lý Sách" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button.Content>

                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource MenuBtn}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActivePage, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="Books">
                                <Setter Property="Background" Value="#50FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Click="BtnReaders_Click">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <fa:IconImage Icon="Users" 
                      Width="22" Height="22" Margin="0,0,15,0"
                      Foreground="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>

                        <TextBlock Text="Quản lý Độc giả" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button.Content>

                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource MenuBtn}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActivePage, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="Readers">
                                <Setter Property="Background" Value="#50FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Click="BtnBorrowing_Click">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <fa:IconImage Icon="ArrowRotateLeft" 
                      Width="22" Height="22" Margin="0,0,15,0"
                      Foreground="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>

                        <TextBlock Text="Mượn / Trả" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button.Content>

                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource MenuBtn}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActivePage, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="Borrowing">
                                <Setter Property="Background" Value="#50FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Click="BtnReport_Click">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <fa:IconImage Icon="ChartColumn" 
                      Width="22" Height="22" Margin="0,0,15,0"
                      Foreground="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>

                        <TextBlock Text="Báo cáo" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button.Content>

                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource MenuBtn}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActivePage, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="Report">
                                <Setter Property="Background" Value="#50FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Border Height="1" Background="#30FFFFFF" Margin="20,40,20,40"/>

            <Button Click="BtnLogout_Click" Style="{DynamicResource MenuBtn}" Foreground="#FF6B6B">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <fa:IconImage Icon="SignOut" 
                      Width="22" Height="22" Margin="0,0,15,0"
                      Foreground="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>

                        <TextBlock Text="Đăng xuất" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button.Content>
            </Button>
        </StackPanel>
    </Border>
</UserControl>