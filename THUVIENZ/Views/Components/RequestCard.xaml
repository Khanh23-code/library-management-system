<UserControl x:Class="THUVIENZ.Views.Components.RequestCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="350" Height="220" Margin="0,0,25,25">

    <Border Background="White" CornerRadius="25">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.15" ShadowDepth="5" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="20" Margin="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.2" ShadowDepth="3"/>
                </Border.Effect>
                <Border.Background>
                    <ImageBrush ImageSource="{Binding AvatarSource, RelativeSource={RelativeSource AncestorType=UserControl}}" Stretch="UniformToFill"/>
                </Border.Background>
            </Border>

            <Grid Grid.Column="1" Margin="5,20,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" VerticalAlignment="Top">
                    <TextBlock FontSize="15" Foreground="#374151" Margin="0,0,0,6">
                        <Run Text="Tên: " FontWeight="SemiBold"/>
                        <Run Text="{Binding ReaderName, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    </TextBlock>
                    <TextBlock FontSize="14" Foreground="#4B5563" Margin="0,0,0,6">
                        <Run Text="Địa chỉ: " FontWeight="SemiBold"/>
                        <Run Text="{Binding Address, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    </TextBlock>
                    <TextBlock FontSize="14" Foreground="#4B5563" Margin="0,0,0,6">
                        <Run Text="Giới tính: " FontWeight="SemiBold"/>
                        <Run Text="{Binding Gender, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    </TextBlock>
                    <TextBlock FontSize="14" Foreground="#4B5563" Margin="0,0,0,6">
                        <Run Text="Email: " FontWeight="SemiBold"/>
                        <Run Text="{Binding Email, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    </TextBlock>
                    <TextBlock FontSize="14" Foreground="#4B5563">
                        <Run Text="SĐT: " FontWeight="SemiBold"/>
                        <Run Text="{Binding Phone, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="Từ chối" Background="#FEF2F2" Foreground="#DC2626" 
                            FontWeight="Bold" FontSize="13" Cursor="Hand"
                            Width="80" Height="32" Margin="0,0,10,0" Click="BtnReject_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FEE2E2"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="Cấp tài khoản" Background="#10B981" Foreground="White" 
                            FontWeight="Bold" FontSize="13" Cursor="Hand"
                            Width="100" Height="32" Click="BtnAccept_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#059669"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>