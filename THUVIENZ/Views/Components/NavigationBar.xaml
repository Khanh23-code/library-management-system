<UserControl x:Class="THUVIENZ.NavigationBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:THUVIENZ"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp">
    <UserControl.Resources>
        <Style x:Key="MenuBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="25,15"/>
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30FFFFFF"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Height="620" Margin="40,0,0,0" CornerRadius="35" Background="#60000000">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="5" Color="Black"/>
        </Border.Effect>
        <StackPanel Margin="0,40,0,10">
            <TextBlock Text="📚 Librix" FontSize="36" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,60"/>

            <Button Click="BtnProfile_Click">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <fa:IconImage Icon="User"
                                      Width="22" Height="22" Margin="0,0,15,0"
                                      Foreground="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>

                        <TextBlock Text="Hồ sơ cá nhân" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button.Content>

                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource MenuBtn}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActivePage, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="Profile">
                                <Setter Property="Background" Value="#50FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Click="BtnFavorite_Click">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <fa:IconImage Icon="Heart" 
                                      Width="22" Height="22" Margin="0,0,15,0"
                                      Foreground="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>

                        <TextBlock Text="Sách yêu thích" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button.Content>
                
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource MenuBtn}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActivePage, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="Favorite">
                                <Setter Property="Background" Value="#50FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Click="BtnSearch_Click">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <fa:IconImage Icon="MagnifyingGlass" 
                      Width="22" Height="22" Margin="0,0,15,0"
                      Foreground="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>

                        <TextBlock Text="Tìm kiếm" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button.Content>

                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource MenuBtn}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActivePage, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="Search">
                                <Setter Property="Background" Value="#50FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Click="BtnBorrowing_Click">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <fa:IconImage Icon="Book" 
                      Width="22" Height="22" Margin="0,0,15,0"
                      Foreground="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>

                        <TextBlock Text="Đang mượn" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button.Content>

                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource MenuBtn}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActivePage, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="Borrowing">
                                <Setter Property="Background" Value="#50FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Click="BtnNotifications_Click">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <fa:IconImage Icon="Bell" 
                      Width="22" Height="22" Margin="0,0,15,0"
                      Foreground="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>

                        <TextBlock Text="Thông báo" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button.Content>

                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource MenuBtn}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActivePage, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="Notifications">
                                <Setter Property="Background" Value="#50FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Border Height="1" Background="#30FFFFFF" Margin="20"/>

            <Button Click="BtnLogout_Click" Style="{DynamicResource MenuBtn}" Foreground="#FF6B6B">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <fa:IconImage Icon="SignOut" 
                      Width="22" Height="22" Margin="0,0,15,0"
                      Foreground="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>

                        <TextBlock Text="Đăng xuất" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button.Content>
            </Button>
        </StackPanel>
    </Border>
</UserControl>