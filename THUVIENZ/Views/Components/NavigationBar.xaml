<UserControl x:Class="THUVIENZ.NavigationBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:THUVIENZ">
    <UserControl.Resources>
        <Style x:Key="MenuBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="25,15"/>
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30FFFFFF"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Margin="25,25,0,25" CornerRadius="35" Background="#60000000">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="5" Color="Black"/>
        </Border.Effect>
        <StackPanel Margin="0,40,0,10">
            <TextBlock Text="📚 Librix" FontSize="36" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,60"/>

            <Button Content="👤  Hồ sơ cá nhân" Click="BtnProfile_Click" Style="{DynamicResource MenuBtn}"/>
            <Button Content="❤️  Sách yêu thích" Click="BtnFavorite_Click" Style="{DynamicResource MenuBtn}"/>
            <Button Content="🔍  Tìm kiếm sách" Click="BtnSearch_Click" Style="{DynamicResource MenuBtn}"/>
            <Button Content="💰  Đang mượn" Click="BtnBorrowing_Click" Style="{DynamicResource MenuBtn}"/>
            <Button Content="📜  Thông báo" Click="BtnNotifications_Click" Style="{DynamicResource MenuBtn}"/>

            <Border Height="1" Background="#30FFFFFF" Margin="20,40,20,40"/>

            <Button Content="🚪  Đăng xuất" Click="BtnLogout_Click" Style="{DynamicResource MenuBtn}" Foreground="#FF6B6B"/>
        </StackPanel>
    </Border>
</UserControl>