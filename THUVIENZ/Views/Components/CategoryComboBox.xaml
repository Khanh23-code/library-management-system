<UserControl x:Class="THUVIENZ.Views.Components.CategoryComboBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="root">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#F9FAFB" CornerRadius="10" Height="38" BorderBrush="#E5E7EB" BorderThickness="1">
            <ComboBox x:Name="cboCategories" 
                      Background="Transparent" 
                      BorderThickness="0" 
                      VerticalContentAlignment="Center" 
                      Padding="10,0"
                      DisplayMemberPath="TenTheLoai"
                      SelectedValuePath="MaTheLoai"
                      SelectedValue="{Binding SelectedCategoryId, ElementName=root, Mode=TwoWay}"
                      SelectionChanged="CboCategories_SelectionChanged">
            </ComboBox>
        </Border>

        <Button Grid.Column="1" Content="Thêm" Background="#ECFDF5" Foreground="#059669" FontWeight="SemiBold" 
                BorderThickness="0" Cursor="Hand" Padding="12,0" Margin="6,0,0,0" Height="38"
                Click="BtnAdd_Click">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Button.Resources>
        </Button>

        <Button Grid.Column="2" Content="Xóa" Background="#FEF2F2" Foreground="#DC2626" FontWeight="SemiBold" 
                BorderThickness="0" Cursor="Hand" Padding="12,0" Margin="6,0,0,0" Height="38"
                Click="BtnDelete_Click">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</UserControl>
