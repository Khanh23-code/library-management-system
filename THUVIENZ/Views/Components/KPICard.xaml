<UserControl x:Class="THUVIENZ.Views.Components.KPICard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             x:Name="root"
             Height="120" Width="240">
    
    <Border Background="White" CornerRadius="20" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.05" ShadowDepth="3" Color="Black"/>
        </Border.Effect>
        
        <Grid Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="{Binding ElementName=root, Path=CardTitle}" 
                           FontSize="14" FontWeight="SemiBold" Foreground="#6B7280" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding ElementName=root, Path=CardValue}" 
                           FontSize="28" FontWeight="Bold" Foreground="#111827"/>
            </StackPanel>

            <Border Grid.Column="1" Width="50" Height="50" CornerRadius="25" 
                    Background="{Binding ElementName=root, Path=IconBgColor}" 
                    VerticalAlignment="Center">
                <fa:IconImage Icon="{Binding ElementName=root, Path=CardIcon}" 
                              Width="24" Height="24" 
                              Foreground="{Binding ElementName=root, Path=IconColor}"/>
            </Border>
        </Grid>
    </Border>
</UserControl>