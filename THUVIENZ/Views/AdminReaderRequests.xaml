<UserControl x:Class="THUVIENZ.Views.AdminReaderRequests"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:comp="clr-namespace:THUVIENZ.Views.Components">

    <Grid>
        <Border Background="White" CornerRadius="35" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="900" MaxWidth="1000" Height="620">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Opacity="0.2" ShadowDepth="10" Color="Black"/>
            </Border.Effect>

            <Grid Margin="60,50,60,50">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,30">
                    <StackPanel HorizontalAlignment="Left">
                        <TextBlock Text="Yêu cầu Đăng ký" FontSize="36" FontWeight="Bold" Foreground="#111827"/>
                        <TextBlock Text="Phê duyệt hoặc từ chối các yêu cầu tạo tài khoản mới" FontSize="16" Foreground="#6B7280" Margin="0,5,0,0"/>
                    </StackPanel>

                    <Button Content="← Quay lại danh sách" HorizontalAlignment="Right" VerticalAlignment="Top" 
                            Background="Transparent" Foreground="#4B5563" FontSize="16" FontWeight="Bold" 
                            BorderThickness="0" Cursor="Hand" Click="BtnBack_Click"/>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" BorderThickness="0" Padding="0,5,10,5">
                    <ItemsControl ItemsSource="{Binding PendingAccounts}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <comp:RequestCard ReaderName="{Binding HoTen}" Gender="{Binding GioiTinh}" 
                                                  Email="{Binding Email}" Address="{Binding DiaChi}" 
                                                  Phone="{Binding SoDienThoai}" 
                                                  AcceptCommand="{Binding DataContext.ApproveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  AcceptCommandParameter="{Binding}"
                                                  RejectCommand="{Binding DataContext.RejectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  RejectCommandParameter="{Binding}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>