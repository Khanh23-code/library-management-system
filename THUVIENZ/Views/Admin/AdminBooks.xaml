<UserControl x:Class="THUVIENZ.Views.AdminBooks"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:comp="clr-namespace:THUVIENZ.Views.Components"
             xmlns:pop="clr-namespace:THUVIENZ.Views.Popups">

    <UserControl.Resources>
        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F9FAFB"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#F3F4F6"/>
            <Setter Property="Padding" Value="0,10"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EFF6FF"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F3F4F6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border Background="White" CornerRadius="35"
                HorizontalAlignment="Center" VerticalAlignment="Center" 
                Width="900" Height="620">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Opacity="0.2" ShadowDepth="10" Color="Black"/>
            </Border.Effect>

            <Grid Margin="60,50,60,50">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,30">
                    <TextBlock Text="Quản lý Kho Sách" FontSize="36" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Thêm, sửa, xóa và tra cứu thông tin sách trong thư viện" FontSize="16" Foreground="#6B7280" Margin="0,5,0,0"/>
                </StackPanel>

                <comp:SearchBar Grid.Row="1" SearchText="{Binding SearchKeyword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,30"/>

                <Border Grid.Row="2" Background="White" CornerRadius="20" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" Opacity="0.05" ShadowDepth="2"/>
                    </Border.Effect>

                    <DataGrid x:Name="dgBooks" ItemsSource="{Binding BooksList}" SelectedItem="{Binding SelectedBook}" Style="{StaticResource ModernDataGrid}" Margin="10" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <DataGrid.Columns>
                            <!-- Mã -->
                            <DataGridTextColumn Header="Mã" Binding="{Binding MaSach}" Width="Auto">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="#4B5563"/>
                                        <Setter Property="Margin" Value="8,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            
                            <!-- Thông tin Sách (Tên + ISBN) -->
                            <DataGridTemplateColumn Header="Thông Tin Sách" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center" Margin="5,8">
                                            <TextBlock Text="{Binding TenSach}" FontSize="14" FontWeight="SemiBold" Foreground="#111827" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Background="#F3F4F6" CornerRadius="4" Padding="4,1" Margin="0,0,4,0">
                                                    <TextBlock Text="ISBN" FontSize="10" FontWeight="Bold" Foreground="#6B7280"/>
                                                </Border>
                                                <TextBlock Text="{Binding MaISBN}" FontSize="12" Foreground="#6B7280" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Phân loại & Tác giả -->
                            <DataGridTemplateColumn Header="Tác Giả &amp; Thể Loại" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center" Margin="5,8">
                                            <TextBlock Text="{Binding TacGia}" FontSize="13" FontWeight="Medium" Foreground="#374151" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                            <Border Background="#EEF2FF" BorderBrush="#C7D2FE" BorderThickness="1" CornerRadius="6" Padding="6,2" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding TheLoaiSach.TenTheLoai}" FontSize="11" FontWeight="SemiBold" Foreground="#4F46E5" TextTrimming="CharacterEllipsis" MaxWidth="150"/>
                                            </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Thông tin Xuất bản -->
                            <DataGridTemplateColumn Header="Xuất Bản" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center" Margin="5,8">
                                            <TextBlock Text="{Binding NhaXuatBan}" FontSize="13" Foreground="#374151" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                            <TextBlock FontSize="12" Foreground="#6B7280">
                                                <Run Text="{Binding NamXuatBan}"/>
                                                <Run Text=" • "/>
                                                <Run Text="{Binding NgonNgu}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Quản Lý / Kho & Giá -->
                            <DataGridTemplateColumn Header="Quản Lý / Giá &amp; Kho" Width="185">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Right" Margin="5,8">
                                            <TextBlock Text="{Binding TriGia, ConverterCulture='vi-VN', StringFormat=\{0:N0\} đ}" FontSize="14" FontWeight="Bold" Foreground="#059669" HorizontalAlignment="Right" Margin="0,0,0,6"/>
                                            
                                            <!-- Tích hợp cực kỳ thông minh: Số lượng kho đặt cạnh các nút thao tác Sửa/Xóa tinh gọn -->
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <TextBlock Text="Kho: " FontSize="12" Foreground="#6B7280" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding SoLuong}" FontSize="12" FontWeight="SemiBold" Foreground="#111827" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                
                                                <Button Content="Sửa" Cursor="Hand" Width="42" Height="24" Margin="0,0,4,0" Click="BtnEditRow_Click" ToolTip="Sửa thông tin sách">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="btnBorder" Background="#EFF6FF" CornerRadius="6">
                                                                <TextBlock Text="Sửa" Foreground="#2563EB" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="btnBorder" Property="Background" Value="#DBEAFE"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>

                                                <Button Content="Xóa" Cursor="Hand" Width="42" Height="24" ToolTip="Xóa sách này"
                                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="btnBorder" Background="#FEF2F2" CornerRadius="6">
                                                                <TextBlock Text="Xóa" Foreground="#DC2626" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="btnBorder" Property="Background" Value="#FEE2E2"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Button Grid.Row="3" Content="+ Thêm sách mới" Click="BtnShowAddPopup_Click" HorizontalAlignment="Right" Width="180" Height="50" Background="#10B981" Foreground="White" FontSize="18" FontWeight="Bold" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#059669"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <pop:AddBookPopup x:Name="AddPopup" Visibility="Collapsed"/>
    </Grid>
</UserControl>