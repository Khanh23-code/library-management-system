<UserControl x:Class="THUVIENZ.Views.AdminBorrowing"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:comp="clr-namespace:THUVIENZ.Views.Components">

    <UserControl.Resources>
        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F9FAFB"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#F3F4F6"/>
            <Setter Property="Padding" Value="0,10"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EFF6FF"/>
                    <Setter Property="Foreground" Value="#1D4ED8"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F3F4F6"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border Background="White" CornerRadius="35"
                HorizontalAlignment="Center" VerticalAlignment="Center" 
                Width="900" Height="620">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Opacity="0.2" ShadowDepth="10" Color="Black"/>
            </Border.Effect>

            <Grid Margin="30,25,30,25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="Quản lý Mượn / Trả" FontSize="32" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Theo dõi trạng thái sách đang được mượn và ghi nhận trả sách" FontSize="14" Foreground="#6B7280" Margin="0,3,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                    <Border Background="#EFF6FF" BorderBrush="#3B82F6" BorderThickness="0,0,0,2" Padding="15,8" Margin="0,0,8,0" Cursor="Hand">
                        <TextBlock Text="Đang mượn (Hiện tại)" FontSize="15" FontWeight="Bold" Foreground="#1D4ED8"/>
                    </Border>
                    <Border Background="Transparent" BorderBrush="Transparent" BorderThickness="0,0,0,2" Padding="15,8" Margin="0,0,8,0" Cursor="Hand">
                        <TextBlock Text="Lịch sử (Đã xong)" FontSize="15" FontWeight="SemiBold" Foreground="#6B7280"/>
                    </Border>
                    <Border Background="Transparent" BorderBrush="Transparent" BorderThickness="0,0,0,2" Padding="15,8" Cursor="Hand">
                        <TextBlock Text="Quy định &amp; Xử phạt" FontSize="15" FontWeight="SemiBold" Foreground="#6B7280"/>
                    </Border>
                </StackPanel>

                <!-- Bố cục 2 cột Quản lý mượn trả (Tab 1 & Tab 2) -->
                <Grid Grid.Row="2" Visibility="{Binding IsCirculationVisible}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3.6*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="6.4*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#F9FAFB" CornerRadius="16" BorderBrush="#E5E7EB" BorderThickness="1">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Native compact inline search box riêng biệt cho AdminBorrowing với icon tối giản thanh lịch -->
                            <Border Grid.Row="0" Background="White" CornerRadius="8" BorderBrush="#D1D5DB" BorderThickness="1" Height="36" Margin="0,0,0,10">
                                <Grid>
                                    <TextBlock Text="Nhập thông tin độc giả..." Foreground="#9CA3AF" FontSize="12" VerticalAlignment="Center" Margin="10,0,0,0" IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ElementName=txtSearchReader, Path=Text}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ElementName=txtSearchReader, Path=Text}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <TextBox x:Name="txtSearchReader" Text="{Binding DataContext.SearchKeyword, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" 
                                             Background="Transparent" BorderThickness="0" FontSize="12" VerticalContentAlignment="Center" Padding="10,0,30,0" Foreground="#111827"/>

                                    <!-- Icon tìm kiếm tối giản thanh lịch, không bo viền nhựa thô -->
                                    <TextBlock Text="⌕" FontSize="18" FontWeight="Bold" Foreground="#9CA3AF" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" IsHitTestVisible="False"/>
                                </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <DataGrid x:Name="dgReaders" ItemsSource="{Binding ReadersList}" SelectedItem="{Binding SelectedReader}" Style="{StaticResource ModernDataGrid}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID" Binding="{Binding MaDocGia}" Width="50"/>
                                        <DataGridTextColumn Header="Độc Giả" Binding="{Binding HoTen}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Background="White" CornerRadius="16" BorderBrush="#E5E7EB" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" Opacity="0.05" ShadowDepth="2"/>
                        </Border.Effect>

                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Chi tiết Giao dịch Mượn / Trả" FontSize="17" FontWeight="Bold" Foreground="#111827"/>
                                    <TextBlock x:Name="txtSelectedReader" Text="{Binding SelectedReader.HoTen, TargetNullValue='Vui lòng chọn một độc giả...'}" FontSize="13" Foreground="#4285F4" FontWeight="SemiBold" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <DataGrid x:Name="dgBooks" ItemsSource="{Binding BorrowedBooks}" Style="{StaticResource ModernDataGrid}">
                                    <DataGrid.Columns>
                                        <!-- Cột 1: Thông tin sách và mã vật lý -->
                                        <DataGridTemplateColumn Header="Sách &amp; Mã" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel VerticalAlignment="Center" Margin="5,8">
                                                        <TextBlock Text="{Binding TenSach}" FontSize="14" FontWeight="SemiBold" Foreground="#111827" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                                        <Border Background="#F3F4F6" CornerRadius="6" Padding="6,3" HorizontalAlignment="Left">
                                                            <TextBlock Text="{Binding MaCuonSach, StringFormat='Mã vật lý: CS-{0}'}" FontSize="12" FontWeight="Medium" Foreground="#4B5563"/>
                                                        </Border>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- Cột 2: Thời hạn Mượn và Hạn trả được mở rộng tuyệt đối không wrap header/content -->
                                        <DataGridTemplateColumn Header="Thời Hạn" Width="135">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel VerticalAlignment="Center" Margin="5,8">
                                                        <TextBlock FontSize="12" Foreground="#6B7280" Margin="0,0,0,3">
                                                            <Run Text="Mượn: "/>
                                                            <Run Text="{Binding NgayMuon, StringFormat=dd/MM/yyyy}" FontWeight="Medium" Foreground="#374151"/>
                                                        </TextBlock>
                                                        <TextBlock FontSize="12" Foreground="#D97706" FontWeight="SemiBold">
                                                            <Run Text="Hạn: "/>
                                                            <Run Text="{Binding HanTra, StringFormat=dd/MM/yyyy}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- Cột 3: Trạng thái thực tế và Tiền phạt -->
                                        <DataGridTemplateColumn Header="Thực Tế" Width="110">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel VerticalAlignment="Center" Margin="5,8">
                                                        <ContentControl Content="{Binding NgayTra}">
                                                            <ContentControl.Style>
                                                                <Style TargetType="ContentControl">
                                                                    <Setter Property="ContentTemplate">
                                                                        <Setter.Value>
                                                                            <DataTemplate>
                                                                                <TextBlock Text="{Binding StringFormat='Trả: {0:dd/MM/yyyy}'}" FontSize="12" FontWeight="SemiBold" Foreground="#10B981" Margin="0,0,0,3"/>
                                                                            </DataTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                    <Style.Triggers>
                                                                        <Trigger Property="Content" Value="{x:Null}">
                                                                            <Setter Property="ContentTemplate">
                                                                                <Setter.Value>
                                                                                    <DataTemplate>
                                                                                        <TextBlock Text="⏳ Chưa trả" FontSize="12" FontWeight="SemiBold" Foreground="#EF4444" Margin="0,0,0,3"/>
                                                                                    </DataTemplate>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ContentControl.Style>
                                                        </ContentControl>
                                                        
                                                        <TextBlock Text="{Binding TienPhat, StringFormat='Phạt: {0:N0} đ'}" FontSize="12" FontWeight="Bold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#EF4444"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding TienPhat}" Value="0">
                                                                            <Setter Property="Foreground" Value="#9CA3AF"/>
                                                                            <Setter Property="FontWeight" Value="Normal"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- Cột 4: Thao tác nhận trả đồng bộ hoàn hảo style project -->
                                        <DataGridTemplateColumn Header="Thao Tác" Width="110">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="{Binding ActionText}" IsEnabled="{Binding IsActionEnabled}" 
                                                            Command="{Binding DataContext.ReturnBookCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                            CommandParameter="{Binding}" FontWeight="Bold" FontSize="12" BorderThickness="0" Cursor="Hand"
                                                            Width="85" Height="32" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Background" Value="#10B981"/>
                                                                <Setter Property="Foreground" Value="White"/>
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsEnabled" Value="False">
                                                                        <Setter Property="Background" Value="#E5E7EB"/>
                                                                        <Setter Property="Foreground" Value="#9CA3AF"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#059669"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Bảng điều khiển Quản lý Cơ chế & Chính sách Xử phạt (Tab 3) -->
                <Grid Grid.Row="2" Visibility="{Binding IsSettingsVisible}">
                    <Border Background="White" CornerRadius="16" BorderBrush="#E5E7EB" BorderThickness="1" Padding="24">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" Opacity="0.05" ShadowDepth="2"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                <TextBlock Text="Cấu hình Quy định &amp; Hạn mức Xử phạt" FontSize="20" FontWeight="Bold" Foreground="#111827"/>
                                <TextBlock Text="Thiết lập các tham số tự động áp dụng khi chốt mượn trả và xử lý nợ đọng" FontSize="14" Foreground="#4B5563" Margin="0,3,0,0"/>
                            </StackPanel>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel MaxWidth="620" HorizontalAlignment="Left">
                                    <!-- Thẻ 1: Tiền phạt mỗi ngày -->
                                    <Border Background="#F9FAFB" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18" Margin="0,0,0,14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="200"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Mức phạt trễ hạn mỗi ngày" FontSize="15" FontWeight="Bold" Foreground="#111827"/>
                                                <TextBlock Text="Số tiền phạt tự động nhân với số ngày trả trễ (VNĐ/ngày)" FontSize="13" Foreground="#6B7280" Margin="0,3,0,0"/>
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Text="{Binding TienPhatMoiNgay, UpdateSourceTrigger=PropertyChanged}" 
                                                     PreviewTextInput="NumberOnly_PreviewTextInput"
                                                     Height="38" FontSize="15" FontWeight="Bold" Foreground="#111827" VerticalContentAlignment="Center" HorizontalContentAlignment="Right" 
                                                     Padding="12,0" Background="White" BorderBrush="#D1D5DB" BorderThickness="1"/>
                                        </Grid>
                                    </Border>

                                    <!-- Thẻ 2: Hạn mức nợ tối đa -->
                                    <Border Background="#F9FAFB" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18" Margin="0,0,0,14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="200"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Ngưỡng nợ đọng tối đa" FontSize="15" FontWeight="Bold" Foreground="#111827"/>
                                                <TextBlock Text="Tổng nợ tích lũy vượt mức này sẽ tự động đình chỉ (Khóa) tài khoản" FontSize="13" Foreground="#6B7280" Margin="0,3,0,0"/>
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Text="{Binding TongNoToiDa, UpdateSourceTrigger=PropertyChanged}" 
                                                     PreviewTextInput="NumberOnly_PreviewTextInput"
                                                     Height="38" FontSize="15" FontWeight="Bold" Foreground="#111827" VerticalContentAlignment="Center" HorizontalContentAlignment="Right" 
                                                     Padding="12,0" Background="White" BorderBrush="#D1D5DB" BorderThickness="1"/>
                                        </Grid>
                                    </Border>

                                    <!-- Thẻ 3: Số ngày mượn tối đa -->
                                    <Border Background="#F9FAFB" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18" Margin="0,0,0,14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="200"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Thời hạn mượn sách tối đa" FontSize="15" FontWeight="Bold" Foreground="#111827"/>
                                                <TextBlock Text="Số ngày mặc định từ lúc mượn đến hạn trả (Ngày)" FontSize="13" Foreground="#6B7280" Margin="0,3,0,0"/>
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Text="{Binding SoNgayMuonToiDa, UpdateSourceTrigger=PropertyChanged}" 
                                                     PreviewTextInput="NumberOnly_PreviewTextInput"
                                                     Height="38" FontSize="15" FontWeight="Bold" Foreground="#111827" VerticalContentAlignment="Center" HorizontalContentAlignment="Right" 
                                                     Padding="12,0" Background="White" BorderBrush="#D1D5DB" BorderThickness="1"/>
                                        </Grid>
                                    </Border>

                                    <!-- Thẻ 4: Số sách tối đa -->
                                    <Border Background="#F9FAFB" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18" Margin="0,0,0,14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="200"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Số lượng sách mượn tối đa" FontSize="15" FontWeight="Bold" Foreground="#111827"/>
                                                <TextBlock Text="Hạn mức số cuốn sách vật lý tối đa được giữ cùng lúc (Cuốn)" FontSize="13" Foreground="#6B7280" Margin="0,3,0,0"/>
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Text="{Binding SoSachMuonToiDa, UpdateSourceTrigger=PropertyChanged}" 
                                                     PreviewTextInput="NumberOnly_PreviewTextInput"
                                                     Height="38" FontSize="15" FontWeight="Bold" Foreground="#111827" VerticalContentAlignment="Center" HorizontalContentAlignment="Right" 
                                                     Padding="12,0" Background="White" BorderBrush="#D1D5DB" BorderThickness="1"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- Nút Lưu thay đổi đồng bộ hoàn hảo với chuẩn nút chính của project -->
                            <Button Grid.Row="2" Content="Lưu Cấu hình" Command="{Binding SaveSettingsCommand}" 
                                    HorizontalAlignment="Right" Width="180" Height="50" Background="#10B981" Foreground="White" 
                                    FontSize="18" FontWeight="Bold" Cursor="Hand" Margin="0,15,0,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#059669"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>