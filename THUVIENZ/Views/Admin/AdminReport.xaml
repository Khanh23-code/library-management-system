<UserControl x:Class="THUVIENZ.Views.AdminReport"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:comp="clr-namespace:THUVIENZ.Views.Components"
             xmlns:vm="clr-namespace:THUVIENZ.ViewModels"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf">

    <UserControl.Resources>
        <Style x:Key="FilterTabStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" CornerRadius="8" Padding="15,8" Background="Transparent" Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#6B7280"/>
                                        <Setter Property="FontWeight" Value="Medium"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="White"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2" Color="Black"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource Self}}" Value="True">
                                <Setter Property="Foreground" Value="#111827"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <UserControl.DataContext>
        <vm:AdminReportViewModel/>
    </UserControl.DataContext>

    <Viewbox Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center">
        <Border Background="White" CornerRadius="35" 
                Width="1100" MinHeight="750" Margin="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Opacity="0.2" ShadowDepth="10" Color="Black"/>
            </Border.Effect>

            <Grid Margin="50,40,50,40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,25">
                    <TextBlock Text="Báo cáo Thống kê" FontSize="36" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Phân tích dữ liệu hoạt động và xu hướng mượn trả" 
                               FontSize="16" Foreground="#6B7280" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- FILTER BAR -->
                <Grid Grid.Row="1" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Background="#F3F4F6" CornerRadius="12" Padding="4" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="7 Ngày" IsChecked="True" 
                                         Style="{StaticResource FilterTabStyle}"
                                         Command="{Binding ChangeFilterCommand}" CommandParameter="7"/>
                            <RadioButton Content="30 Ngày" 
                                         Style="{StaticResource FilterTabStyle}"
                                         Command="{Binding ChangeFilterCommand}" CommandParameter="30"/>
                            <RadioButton Content="1 Năm" 
                                         Style="{StaticResource FilterTabStyle}"
                                         Command="{Binding ChangeFilterCommand}" CommandParameter="365"/>
                        </StackPanel>
                    </Border>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Command="{Binding ExportCommand}" Cursor="Hand" Margin="0,0,15,0" VerticalAlignment="Center">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="White" CornerRadius="8" Padding="12,6" BorderBrush="#E5E7EB" BorderThickness="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <fa:IconImage Icon="FileDownload" Width="14" Height="14" Foreground="#2563EB" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Xuất Báo cáo" Foreground="#374151" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#F9FAFB"/>
                                            <Setter TargetName="border" Property="BorderBrush" Value="#D1D5DB"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <Border Background="#D1FAE5" CornerRadius="6" Padding="8,4" Margin="0,0,10,0" VerticalAlignment="Center">
                            <TextBlock Text="LIVE DATA" FontSize="10" FontWeight="Bold" Foreground="#059669" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding LastUpdated}" 
                                   FontSize="12" Foreground="#9CA3AF" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- KPI CARDS -->
                <UniformGrid Grid.Row="2" Columns="4" Margin="-10,0,-10,25">
                    <comp:KPICard CardTitle="Tổng Sách" CardValue="{Binding TotalBooks}" 
                                  CardIcon="Book" IconBgColor="#DBEAFE" IconColor="#2563EB"/>

                    <comp:KPICard CardTitle="Độc Giả" CardValue="{Binding TotalReaders}" 
                                  CardIcon="Users" IconBgColor="#D1FAE5" IconColor="#059669"/>

                    <comp:KPICard CardTitle="Đang Mượn" CardValue="{Binding BorrowedBooks}" 
                                  CardIcon="ArrowRightArrowLeft" IconBgColor="#FEF3C7" IconColor="#D97706"/>

                    <comp:KPICard CardTitle="Trễ Hạn" CardValue="{Binding OverdueBooks}" 
                                  CardIcon="ExclamationTriangle" IconBgColor="#FEE2E2" IconColor="#DC2626"/>
                </UniformGrid>

                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.8*"/>
                        <ColumnDefinition Width="1.2*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#F9FAFB" CornerRadius="20" Margin="0,0,10,0" Padding="20">
                        <DockPanel>
                            <TextBlock Text="{Binding TrendTitle}" DockPanel.Dock="Top" FontSize="18" FontWeight="Bold" Foreground="#374151" Margin="0,0,0,15"/>
                            <lvc:CartesianChart Series="{Binding BorrowingTrendSeries}" MinHeight="300">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Labels="{Binding TrendLabels}">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator Step="{Binding LabelStep}" StrokeThickness="0"/>
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis LabelFormatter="{Binding YFormatter}"/>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#F9FAFB" CornerRadius="20" Margin="10,0,0,0" Padding="20">
                        <DockPanel>
                            <TextBlock Text="Thị hiếu Thể loại" DockPanel.Dock="Top" FontSize="18" FontWeight="Bold" Foreground="#374151" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                            <lvc:PieChart Series="{Binding CategoryRatioSeries}" InnerRadius="60" LegendLocation="Bottom" MinHeight="300">
                                <lvc:PieChart.ChartLegend>
                                    <lvc:DefaultLegend BulletSize="15"/>
                                </lvc:PieChart.ChartLegend>
                            </lvc:PieChart>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Viewbox>
</UserControl>