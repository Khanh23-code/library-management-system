<UserControl x:Class="THUVIENZ.Views.AdminReport"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:comp="clr-namespace:THUVIENZ.Views.Components"
             xmlns:vm="clr-namespace:THUVIENZ.ViewModels"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf">

    <UserControl.DataContext>
        <vm:AdminReportViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Border Background="White" CornerRadius="35" 
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="1000" Height="680">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Opacity="0.2" ShadowDepth="10" Color="Black"/>
            </Border.Effect>

            <Grid Margin="50,40,50,40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Báo cáo Thống kê" FontSize="36" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Tổng quan về hoạt động thư viện và thị hiếu độc giả" 
                               FontSize="16" Foreground="#6B7280" Margin="0,5,0,0"/>
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <comp:KPICard Grid.Column="0" CardTitle="Tổng Sách" CardValue="{Binding TotalBooks}" 
                                  CardIcon="Book" IconBgColor="#DBEAFE" IconColor="#2563EB"/>

                    <comp:KPICard Grid.Column="1" CardTitle="Độc Giả" CardValue="{Binding TotalReaders}" 
                                  CardIcon="Users" IconBgColor="#D1FAE5" IconColor="#059669"/>

                    <comp:KPICard Grid.Column="2" CardTitle="Đang Mượn" CardValue="{Binding BorrowedBooks}" 
                                  CardIcon="ArrowRightArrowLeft" IconBgColor="#FEF3C7" IconColor="#D97706"/>

                    <comp:KPICard Grid.Column="3" CardTitle="Trễ Hạn" CardValue="{Binding OverdueBooks}" 
                                  CardIcon="ExclamationTriangle" IconBgColor="#FEE2E2" IconColor="#DC2626"/>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#F9FAFB" CornerRadius="20" Margin="0,0,10,0" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Lượt mượn &amp; Trễ hạn (7 ngày qua)" FontSize="18" FontWeight="Bold" Foreground="#374151" Margin="0,0,0,15"/>
                            <lvc:CartesianChart Series="{Binding BorrowingTrendSeries}" Height="280">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Labels="{Binding TrendLabels}">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator Step="1" StrokeThickness="0"/>
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis LabelFormatter="{Binding YFormatter}"/>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#F9FAFB" CornerRadius="20" Margin="10,0,0,0" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Thị hiếu Thể loại" FontSize="18" FontWeight="Bold" Foreground="#374151" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                            <lvc:PieChart Series="{Binding CategoryRatioSeries}" InnerRadius="50" LegendLocation="Bottom" Height="280">
                                <lvc:PieChart.ChartLegend>
                                    <lvc:DefaultLegend BulletSize="15"/>
                                </lvc:PieChart.ChartLegend>
                            </lvc:PieChart>
                        </StackPanel>
                    </Border>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</UserControl>