<Window x:Class="THUVIENZ.Views.Favorite"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Favorites" Height="900" Width="1400"
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="MenuBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="25,15"/>
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30FFFFFF"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" BorderThickness="1" BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.Background>
        <ImageBrush ImageSource="/Assets/Images/Background.jpg" Stretch="UniformToFill"/>
    </Window.Background>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Margin="25,25,0,25" CornerRadius="35" Background="#60000000">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="5" Color="Black"/>
            </Border.Effect>
            <StackPanel Margin="0,40,0,10">
                <TextBlock Text="📚 Librix" FontSize="36" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,60"/>

                <Button Content="👤  Hồ sơ cá nhân" Click="BtnProfile_Click" Style="{DynamicResource MenuBtn}"/>
                <Button Content="❤️  Sách yêu thích" Background="#40FFFFFF" Foreground="White" Style="{DynamicResource MenuBtn}"/>
                <Button Content="🔍  Tìm kiếm sách" Click="BtnSearch_Click" Style="{DynamicResource MenuBtn}"/>
                <Button Content="💰  Đang mượn" Click="BtnBorrowing_Click" Style="{DynamicResource MenuBtn}"/>
                <Button Content="📜  Thông báo" Click="BtnNotifications_Click" Style="{DynamicResource MenuBtn}"/>

                <Border Height="1" Background="#30FFFFFF" Margin="20,40,20,40"/>

                <Button Content="🚪  Đăng xuất" Click="BtnLogout_Click" Style="{DynamicResource MenuBtn}" Foreground="#FF6B6B"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Margin="25" Background="White" CornerRadius="35">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Opacity="0.2" ShadowDepth="10" Color="Black"/>
            </Border.Effect>

            <Grid Margin="50,40,20,40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="10,0,0,30">
                    <TextBlock Text="Sách yêu thích" FontSize="36" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Những cuốn sách bạn đã lưu lại để đọc sau" FontSize="16" Foreground="#6B7280" Margin="0,5,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" BorderThickness="0" Padding="0,0,20,0">
                    <WrapPanel Orientation="Horizontal">

                        <Border Background="#F9FAFB" CornerRadius="25" Margin="10,10,25,25" Width="450" Height="220">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" Opacity="0.1" ShadowDepth="5" Color="Black"/>
                            </Border.Effect>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" CornerRadius="15" Margin="20">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" Opacity="0.2" ShadowDepth="3"/>
                                    </Border.Effect>
                                    <Border.Background>
                                        <ImageBrush ImageSource="pack://application:,,,/Images/phai.png" Stretch="UniformToFill"/>
                                    </Border.Background>
                                </Border>

                                <Grid Grid.Column="1" Margin="0,20,20,20">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0">
                                        <TextBlock Text="Aam antir bhenpu" FontSize="22" FontWeight="Bold" Foreground="#111827" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="Author: Bibhutibhushan" FontSize="15" Foreground="#6B7280" Margin="0,2,0,0"/>
                                        <TextBlock Text="Book ID: 20511xT" FontSize="14" Foreground="#9CA3AF" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="1" Text="Giá: ₹ 379" FontSize="20" FontWeight="Bold" Foreground="#00C853" VerticalAlignment="Center"/>

                                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="❤" FontSize="18" Foreground="#FF4C4C" Background="#FEE2E2" BorderBrush="Transparent" Width="40" Height="40" Margin="0,0,10,0" Style="{StaticResource CardBtn}" ToolTip="Bỏ yêu thích"/>
                                        <Button Content="Mượn ngay" FontSize="14" Foreground="White" Background="#4285F4" BorderBrush="Transparent" Width="100" Height="40" Style="{StaticResource CardBtn}">
                                            <Button.Triggers>
                                                <EventTrigger RoutedEvent="MouseEnter">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <ColorAnimation Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)" To="#2B6CB0" Duration="0:0:0.2"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                                <EventTrigger RoutedEvent="MouseLeave">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <ColorAnimation Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)" To="#4285F4" Duration="0:0:0.2"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Button.Triggers>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </WrapPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
