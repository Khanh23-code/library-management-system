<Window x:Class="THUVIENZ.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:THUVIENZ"
        WindowState="Maximized"
        Title="Librix - Library Management" Height="720" Width="1280"
        
        WindowStartupLocation="CenterScreen">

    <Window.Background>
        <ImageBrush ImageSource="/Assets/Images/Background.jpg" Stretch="UniformToFill"/>
    </Window.Background>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ContentControl x:Name="NavContainer" Grid.Column="0"/>

        <ContentControl x:Name="MainContent" Grid.Column="1" Margin="20"/>
    </Grid>
</Window>