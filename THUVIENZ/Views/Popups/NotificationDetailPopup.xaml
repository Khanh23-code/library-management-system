<UserControl x:Class="THUVIENZ.Views.Popups.NotificationDetailPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             x:Name="root"
             Visibility="Collapsed">
    <Grid Background="#80000000" MouseLeftButtonUp="Background_MouseLeftButtonUp">

        <Border Background="White" CornerRadius="20" Width="500" MaxHeight="600" 
                VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30"
                MouseLeftButtonUp="Border_MouseLeftButtonUp">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Opacity="0.1" ShadowDepth="5"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding ElementName=root, Path=PopupTitle}" FontSize="20" FontWeight="Bold" Foreground="#111827" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding ElementName=root, Path=PopupTimestamp}" FontSize="13" Foreground="#9CA3AF" Margin="0,5,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="1" Width="50" Height="50" CornerRadius="25" Background="{Binding ElementName=root, Path=IconBgColor}" VerticalAlignment="Top">
                        <fa:IconImage Icon="{Binding ElementName=root, Path=PopupIcon}" Width="24" Height="24" Foreground="{Binding ElementName=root, Path=IconColor}"/>
                    </Border>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,30">
                    <TextBlock Text="{Binding ElementName=root, Path=PopupMessage}" FontSize="16" Foreground="#374151" TextWrapping="Wrap" LineHeight="24"/>
                </ScrollViewer>

                <Button Grid.Row="2" Content="Đóng" FontSize="16" FontWeight="Bold" Foreground="White" Background="#3B82F6" 
                        Padding="0,12" BorderThickness="0" Cursor="Hand" Click="BtnClose_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>