<UserControl x:Class="THUVIENZ.Views.Popups.ReaderActionPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:components="clr-namespace:THUVIENZ.Views.Components"
             HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
             Background="#66000000">

    <UserControl.Resources>
        <!-- Style chuẩn hóa cho các nút Lựa chọn nhanh (Preset Chips) -->
        <Style x:Key="PresetChipStyle" TargetType="Button">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="#4B5563"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" BorderThickness="1" BorderBrush="#E5E7EB">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E5E7EB"/>
                                <Setter Property="Foreground" Value="#111827"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom Template trọn vẹn cho DatePicker để loại bỏ triệt để giao diện Windows mặc định -->
        <Style x:Key="PremiumCustomDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="IsTodayHighlighted" Value="True"/>
            <Setter Property="SelectedDateFormat" Value="Short"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border x:Name="border" Background="#F3F4F6" BorderThickness="1" BorderBrush="#D1D5DB" CornerRadius="10" Height="40">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Phần hiển thị text ngày tháng -->
                                <DatePickerTextBox x:Name="PART_TextBox" Grid.Column="0" 
                                                   HorizontalContentAlignment="Left" VerticalContentAlignment="Center" 
                                                   Padding="12,0,0,0" BorderThickness="0" Background="Transparent" 
                                                   Foreground="#111827" FontSize="14" FontWeight="SemiBold"
                                                   IsReadOnly="True" Cursor="Hand"
                                                   Focusable="False"/>

                                <!-- Icon biểu tượng lịch vector vẽ tay tuyệt đẹp thay thế hoàn toàn icon Windows cũ -->
                                <TextBlock Grid.Column="1" Text="📅" FontSize="16" VerticalAlignment="Center" Margin="0,0,12,0" 
                                           IsHitTestVisible="False" Foreground="#6B7280"/>

                                <!-- Nút bấm vô hình bao trùm toàn bộ diện tích đóng vai trò là PART_Button chuẩn của Framework -->
                                <Button x:Name="PART_Button" Grid.ColumnSpan="2" Cursor="Hand" Opacity="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent"/>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border Background="White" CornerRadius="25" Width="600" VerticalAlignment="Center" HorizontalAlignment="Center" BorderBrush="#E5E7EB" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Opacity="0.25" ShadowDepth="10" Color="Black"/>
            </Border.Effect>

            <Grid Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header Tiêu đề -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Border Width="42" Height="42" Background="{Binding HeaderBgBrush, RelativeSource={RelativeSource AncestorType=UserControl}}" CornerRadius="21" Margin="0,0,15,0">
                        <TextBlock Text="{Binding HeaderIcon, RelativeSource={RelativeSource AncestorType=UserControl}}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{Binding PopupTitle, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                               FontSize="24" FontWeight="Bold" Foreground="{Binding HeaderTextBrush, RelativeSource={RelativeSource AncestorType=UserControl}}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Khung Tóm tắt Thông tin Độc giả -->
                <Border Grid.Row="1" Background="#F9FAFB" CornerRadius="15" Padding="15" BorderThickness="1" BorderBrush="#E5E7EB" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock FontSize="15" Foreground="#111827" FontWeight="SemiBold" Margin="0,0,0,8">
                            <Run Text="Độc giả: " Foreground="#6B7280" FontWeight="Normal"/>
                            <Run Text="{Binding TargetReader.HoTen, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            <Run Text=" (" Foreground="#6B7280" FontWeight="Normal"/>
                            <Run Text="{Binding TargetReader.MaDocGia, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="#6B7280" FontWeight="Normal"/>
                            <Run Text=")" Foreground="#6B7280" FontWeight="Normal"/>
                        </TextBlock>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" FontSize="13" Foreground="#4B5563" TextTrimming="CharacterEllipsis">
                                <Run Text="Email: " FontWeight="SemiBold"/>
                                <Run Text="{Binding TargetReader.Email, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            </TextBlock>
                            <TextBlock Grid.Column="1" FontSize="13" Foreground="#4B5563" TextTrimming="CharacterEllipsis">
                                <Run Text="SĐT: " FontWeight="SemiBold"/>
                                <Run Text="{Binding TargetReader.SoDienThoai, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Khung Nhập Lý do -->
                <StackPanel Grid.Row="2" Margin="0,0,0,15">
                    <TextBlock Text="Lý do xử lý chi tiết:" FontSize="14" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,6"/>
                    <TextBox x:Name="txtReason" Height="65" TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalContentAlignment="Top" Padding="10" FontSize="14"
                             Background="#F3F4F6" BorderThickness="1" BorderBrush="#D1D5DB"
                             Foreground="#111827" 
                             Text="{Binding ReasonText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, RelativeSource={RelativeSource AncestorType=UserControl}}">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </StackPanel>

                <!-- Khung Tùy chỉnh Thời hạn Đình chỉ (Chỉ hiển thị khi chế độ là Suspend) -->
                <StackPanel Grid.Row="3" Margin="0,0,0,25" x:Name="spDuration"
                            Visibility="{Binding DurationVisibility, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    
                    <TextBlock Text="Thiết lập thời hạn đình chỉ:" FontSize="14" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,6"/>
                    
                    <!-- 1. Dãy Preset Chips -->
                    <WrapPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Button Content="1 giờ" Tag="1h" Style="{StaticResource PresetChipStyle}" Click="PresetChip_Click"/>
                        <Button Content="12 giờ" Tag="12h" Style="{StaticResource PresetChipStyle}" Click="PresetChip_Click"/>
                        <Button Content="24 giờ" Tag="24h" Style="{StaticResource PresetChipStyle}" Click="PresetChip_Click"/>
                        <Button Content="1 ngày" Tag="1d" Style="{StaticResource PresetChipStyle}" Click="PresetChip_Click"/>
                        <Button Content="2 ngày" Tag="2d" Style="{StaticResource PresetChipStyle}" Click="PresetChip_Click"/>
                        <Button Content="3 ngày" Tag="3d" Style="{StaticResource PresetChipStyle}" Click="PresetChip_Click"/>
                        <Button Content="7 ngày" Tag="7d" Style="{StaticResource PresetChipStyle}" Click="PresetChip_Click"/>
                        <Button Content="15 ngày" Tag="15d" Style="{StaticResource PresetChipStyle}" Click="PresetChip_Click"/>
                        <Button Content="30 ngày" Tag="30d" Style="{StaticResource PresetChipStyle}" Click="PresetChip_Click"/>
                    </WrapPanel>

                    <!-- 2. Khung Tùy chỉnh (Số ngày & Lịch DatePicker) -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Gõ tay theo số ngày -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Nhập số ngày:" FontSize="12" Foreground="#6B7280" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtDuration" Height="40" VerticalContentAlignment="Center" Padding="12,0" FontSize="14" FontWeight="SemiBold"
                                     Background="#F3F4F6" BorderThickness="1" BorderBrush="#D1D5DB" Foreground="#111827"
                                     TextChanged="TxtDuration_TextChanged">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="10"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </StackPanel>

                        <!-- Chọn lịch cụ thể sử dụng Component Tự thiết kế (CustomDatePicker) tối ưu tuyệt đối -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Đến ngày cụ thể:" FontSize="12" Foreground="#6B7280" Margin="0,0,0,4"/>
                            <components:CustomDatePicker x:Name="dpExpiryDate" OnDateSelected="DpExpiryDate_SelectedDateChanged"/>
                        </StackPanel>
                    </Grid>

                    <!-- 3. Khung Xem trước Thông minh (Dark Premium Liquid Glass Style loại bỏ trọn vẹn icon theo đúng Ảnh 1) -->
                    <Border CornerRadius="22" BorderThickness="1" Margin="0,15,0,0" Height="48" HorizontalAlignment="Stretch" Padding="20,0">
                        <Border.Background>
                            <!-- Nền tối đục mờ cao cấp xám than huyền bí -->
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#E6111827" Offset="0.0"/>
                                <GradientStop Color="#CC1F2937" Offset="0.5"/>
                                <GradientStop Color="#E6111827" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <!-- Viền sáng mờ phản quang thủy tinh rim lighting tinh tế -->
                            <SolidColorBrush Color="#26FFFFFF"/>
                        </Border.BorderBrush>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="6" Opacity="0.3" Color="Black"/>
                        </Border.Effect>

                        <!-- Chuỗi text trắng thuần khiết căn giữa tuyệt đẹp không icon -->
                        <TextBlock Text="{Binding ExpiryPreviewText, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                   FontSize="13.5" FontWeight="SemiBold" Foreground="White" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    </Border>
                </StackPanel>

                <!-- Các nút Thao tác Cuối -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="Hủy bỏ" Height="45" Background="#F3F4F6" Foreground="#4B5563" 
                            FontWeight="Bold" FontSize="15" Cursor="Hand" Click="BtnCancel_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E5E7EB"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Grid.Column="2" Content="{Binding ActionButtonText, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                            Height="45" Background="{Binding ActionButtonBg, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="White" 
                            FontWeight="Bold" FontSize="15" Cursor="Hand" Click="BtnConfirm_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
