<UserControl x:Class="THUVIENZ.Views.Popups.AddBookPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:comp="clr-namespace:THUVIENZ.Views.Components"
             HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

    <Grid>

        <Border Background="White" CornerRadius="30" Width="850" Height="730" 
                VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" Opacity="0.3" ShadowDepth="0" Color="Black"/>
            </Border.Effect>

            <Grid Margin="40,25,40,25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock x:Name="lblPopupTitle" Text="Thêm Sách Mới" FontSize="28" FontWeight="Bold" Foreground="#111827"/>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center" 
                            FontSize="22" Background="Transparent" BorderThickness="0" 
                            Foreground="#9CA3AF" Cursor="Hand" Click="BtnClose_Click"/>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,30,0">
                        <TextBlock Text="Ảnh bìa sách" FontSize="16" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,10"/>
                        <Border Background="#F3F4F6" CornerRadius="20" Height="320" BorderBrush="#E5E7EB" BorderThickness="2">
                            <Grid>
                                <Border CornerRadius="18" ClipToBounds="True">
                                    <Grid>
                                        <StackPanel x:Name="spPlaceholder" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="📷" FontSize="48" HorizontalAlignment="Center" Opacity="0.3"/>
                                            <TextBlock x:Name="tbImageName" Text="Chọn ảnh..." FontSize="14" Foreground="#9CA3AF" Margin="0,10,0,0" TextTrimming="CharacterEllipsis" MaxWidth="240" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        
                                        <!-- Border bo góc hiển thị ảnh nền bằng ImageBrush trỏ tới Source của imgPreview -->
                                        <Border CornerRadius="18">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding Source, ElementName=imgPreview}" Stretch="UniformToFill"/>
                                            </Border.Background>
                                        </Border>
                                        
                                        <!-- imgPreview gốc để ẩn, duy trì toàn bộ logic code-behind -->
                                        <Image x:Name="imgPreview" Visibility="Collapsed"/>
                                    </Grid>
                                </Border>
                                
                                <!-- Nút bấm chọn ảnh với ControlTemplate bo tròn trong suốt hoàn toàn loại bỏ lớp phủ vuông mặc định -->
                                <Button x:Name="btnSelectImage" Cursor="Hand" Click="BtnSelectImage_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="hoverBorder" Background="Transparent" CornerRadius="18"/>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="hoverBorder" Property="Background" Value="#1A000000"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="Tên sách" FontSize="14" FontWeight="SemiBold" Margin="5,0,0,5"/>
                            <Border Background="#F9FAFB" CornerRadius="10" Height="38" BorderBrush="#E5E7EB" BorderThickness="1">
                                <TextBox x:Name="txtTitle" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="10,0"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="Mã ID Sách" FontSize="14" FontWeight="SemiBold" Margin="5,0,0,5"/>
                            <Border Background="#F9FAFB" CornerRadius="10" Height="38" BorderBrush="#E5E7EB" BorderThickness="1">
                                <TextBox x:Name="txtBookID" IsEnabled="False" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="10,0"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,8,0,0">
                            <TextBlock Text="Tên tác giả" FontSize="14" FontWeight="SemiBold" Margin="5,0,0,5"/>
                            <Border Background="#F9FAFB" CornerRadius="10" Height="38" BorderBrush="#E5E7EB" BorderThickness="1">
                                <TextBox x:Name="txtAuthor" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="10,0"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,8,0,0">
                            <TextBlock Text="Thể loại" FontSize="14" FontWeight="SemiBold" Margin="5,0,0,5"/>
                            <comp:CategoryComboBox x:Name="cboCategory" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,8,0,0">
                            <TextBlock Text="Nhà xuất bản" FontSize="14" FontWeight="SemiBold" Margin="5,0,0,5"/>
                            <Border Background="#F9FAFB" CornerRadius="10" Height="38" BorderBrush="#E5E7EB" BorderThickness="1">
                                <TextBox x:Name="txtLang" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="10,0"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,8,0,0">
                            <TextBlock Text="Năm xuất bản" FontSize="14" FontWeight="SemiBold" Margin="5,0,0,5"/>
                            <Border Background="#F9FAFB" CornerRadius="10" Height="38" BorderBrush="#E5E7EB" BorderThickness="1">
                                <TextBox x:Name="txtPageNumber" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="10,0"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,8,0,0">
                            <TextBlock Text="Số lượng" FontSize="14" FontWeight="SemiBold" Margin="5,0,0,5"/>
                            <Border Background="#F9FAFB" CornerRadius="10" Height="38" BorderBrush="#E5E7EB" BorderThickness="1">
                                <TextBox x:Name="txtQuantity" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="10,0"/>
                            </Border>
                        </StackPanel>
                        <StackPanel x:Name="spStatus" Grid.Row="3" Grid.Column="2" Margin="0,8,0,0">
                            <TextBlock Text="Trạng thái" FontSize="14" FontWeight="SemiBold" Margin="5,0,0,5"/>
                            <Border Background="#F9FAFB" CornerRadius="10" Height="38" BorderBrush="#E5E7EB" BorderThickness="1">
                                <TextBox x:Name="txtStatus" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="10,0"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,8,0,0">
                            <TextBlock Text="Ngôn ngữ" FontSize="14" FontWeight="SemiBold" Margin="5,0,0,5"/>
                            <Border Background="#F9FAFB" CornerRadius="10" Height="38" BorderBrush="#E5E7EB" BorderThickness="1">
                                <TextBox x:Name="txtRealLang" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="10,0"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Row="4" Grid.Column="2" Margin="0,8,0,0">
                            <TextBlock Text="Trị giá (VNĐ)" FontSize="14" FontWeight="SemiBold" Margin="5,0,0,5"/>
                            <Border Background="#F9FAFB" CornerRadius="10" Height="38" BorderBrush="#E5E7EB" BorderThickness="1">
                                <TextBox x:Name="txtPrice" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="10,0" TextChanged="TxtPrice_TextChanged"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,8,0,0">
                            <TextBlock Text="Mô tả nội dung" FontSize="14" FontWeight="SemiBold" Margin="5,0,0,5"/>
                            <Border Background="#F9FAFB" CornerRadius="10" Height="65" BorderBrush="#E5E7EB" BorderThickness="1">
                                <TextBox x:Name="txtDescription" Background="Transparent" BorderThickness="0" Padding="10,8" 
                                         TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Content="Hoàn tác" Width="120" Height="45" Background="#F3F4F6" Foreground="#4B5563" 
                            FontWeight="Bold" Margin="0,0,15,0" Cursor="Hand" Click="BtnUndo_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E5E7EB"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button x:Name="btnSaveContent" Content="Thêm sách" Width="180" Height="45" Background="#10B981" Foreground="White" 
                            FontWeight="Bold" Cursor="Hand" Click="BtnSave_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2B6CB0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>