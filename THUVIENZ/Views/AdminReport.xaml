<UserControl x:Class="THUVIENZ.Views.AdminReport"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:comp="clr-namespace:THUVIENZ.Views.Components"
             xmlns:vm="clr-namespace:THUVIENZ.ViewModels"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf">

    <UserControl.Resources>
        <Style x:Key="FilterTabStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" CornerRadius="8" Padding="15,8" Background="Transparent" Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#6B7280"/>
                                        <Setter Property="FontWeight" Value="Medium"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="White"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2" Color="Black"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource Self}}" Value="True">
                                <Setter Property="Foreground" Value="#111827"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <UserControl.DataContext>
        <vm:AdminReportViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Border Background="White" CornerRadius="35" 
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="1000" Height="680">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Opacity="0.2" ShadowDepth="10" Color="Black"/>
            </Border.Effect>

            <Grid Margin="60,50,60,50">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,30">
                    <TextBlock Text="Báo cáo Thống kê" FontSize="36" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Phân tích dữ liệu hoạt động và xu hướng mượn trả" 
                               FontSize="16" Foreground="#6B7280" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- FILTER BAR (Sychronized with project style) -->
                <Grid Grid.Row="1" Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Background="#F3F4F6" CornerRadius="12" Padding="4" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="7 Ngày" IsChecked="True" 
                                         Style="{StaticResource FilterTabStyle}"
                                         Command="{Binding ChangeFilterCommand}" CommandParameter="7"/>
                            <RadioButton Content="30 Ngày" 
                                         Style="{StaticResource FilterTabStyle}"
                                         Command="{Binding ChangeFilterCommand}" CommandParameter="30"/>
                            <RadioButton Content="1 Năm" 
                                         Style="{StaticResource FilterTabStyle}"
                                         Command="{Binding ChangeFilterCommand}" CommandParameter="365"/>
                        </StackPanel>
                    </Border>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#D1FAE5" CornerRadius="6" Padding="8,4" Margin="0,0,10,0">
                            <TextBlock Text="LIVE DATA" FontSize="10" FontWeight="Bold" Foreground="#059669"/>
                        </Border>
                        <TextBlock Text="Cập nhật 1 phút trước" 
                                   FontSize="12" Foreground="#9CA3AF" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2" Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <comp:KPICard Grid.Column="0" CardTitle="Tổng Sách" CardValue="{Binding TotalBooks}" 
                                  CardIcon="Book" IconBgColor="#DBEAFE" IconColor="#2563EB"/>

                    <comp:KPICard Grid.Column="1" CardTitle="Độc Giả" CardValue="{Binding TotalReaders}" 
                                  CardIcon="Users" IconBgColor="#D1FAE5" IconColor="#059669"/>

                    <comp:KPICard Grid.Column="2" CardTitle="Đang Mượn" CardValue="{Binding BorrowedBooks}" 
                                  CardIcon="ArrowRightArrowLeft" IconBgColor="#FEF3C7" IconColor="#D97706"/>

                    <comp:KPICard Grid.Column="3" CardTitle="Trễ Hạn" CardValue="{Binding OverdueBooks}" 
                                  CardIcon="ExclamationTriangle" IconBgColor="#FEE2E2" IconColor="#DC2626"/>
                </Grid>

                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#F9FAFB" CornerRadius="20" Margin="0,0,10,0" Padding="20">
                        <StackPanel>
                            <TextBlock Text="{Binding TrendTitle}" FontSize="18" FontWeight="Bold" Foreground="#374151" Margin="0,0,0,15"/>
                            <lvc:CartesianChart Series="{Binding BorrowingTrendSeries}" Height="280">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Labels="{Binding TrendLabels}">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator Step="1" StrokeThickness="0"/>
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis LabelFormatter="{Binding YFormatter}"/>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#F9FAFB" CornerRadius="20" Margin="10,0,0,0" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Thị hiếu Thể loại" FontSize="18" FontWeight="Bold" Foreground="#374151" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                            <lvc:PieChart Series="{Binding CategoryRatioSeries}" InnerRadius="50" LegendLocation="Bottom" Height="280">
                                <lvc:PieChart.ChartLegend>
                                    <lvc:DefaultLegend BulletSize="15"/>
                                </lvc:PieChart.ChartLegend>
                            </lvc:PieChart>
                        </StackPanel>
                    </Border>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</UserControl>