<UserControl x:Class="THUVIENZ.Views.AdminReaders"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:comp="clr-namespace:THUVIENZ.Views.Components"
             xmlns:pop="clr-namespace:THUVIENZ.Views.Popups">

    <Grid>
        <Border Background="White" CornerRadius="35"
                HorizontalAlignment="Center" VerticalAlignment="Center" 
                Width="900" Height="620">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Opacity="0.2" ShadowDepth="10" Color="Black"/>
            </Border.Effect>

            <Grid Margin="60,50,60,50">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,30">
                    <StackPanel HorizontalAlignment="Left">
                        <TextBlock Text="Quản lý Độc giả" FontSize="36" FontWeight="Bold" Foreground="#111827"/>
                        <TextBlock Text="Quản lý thông tin, tìm kiếm và xóa tài khoản của độc giả" FontSize="16" Foreground="#6B7280" Margin="0,5,0,0"/>
                    </StackPanel>

                    <Button Content="🔔 Xem Yêu cầu (2)" HorizontalAlignment="Right" VerticalAlignment="Center" 
                            Width="160" Height="45" Background="#F59E0B" Foreground="White" 
                            FontSize="16" FontWeight="Bold" Cursor="Hand" Click="BtnViewRequests_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D97706"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <comp:SearchBar Grid.Row="1" Margin="0,0,0,20"/>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" BorderThickness="0" Margin="0,0,0,20" Padding="0,5,10,5">
                    <WrapPanel Orientation="Horizontal">
                        <comp:ReaderCard ReaderName="Nguyễn Văn A" ReaderId="RD-20511" Address="TP.HCM" Gender="Nam" Email="nguyenvana@gmail.com" Phone="0901234567" AvatarSource="/Assets/phai.png" OnDeleteClick="ReaderCard_OnDeleteClick"/>
                        <comp:ReaderCard ReaderName="Trần Thị B" ReaderId="RD-20512" Address="Hà Nội" Gender="Nữ" Email="tranthib@outlook.com" Phone="0987654321" AvatarSource="/Assets/phai.png" OnDeleteClick="ReaderCard_OnDeleteClick"/>
                        <comp:ReaderCard ReaderName="Lê Văn C" ReaderId="RD-20513" Address="Đà Nẵng" Gender="Nam" Email="levanc@gmail.com" Phone="0912345678" AvatarSource="/Assets/phai.png" OnDeleteClick="ReaderCard_OnDeleteClick"/>
                    </WrapPanel>
                </ScrollViewer>

            </Grid>
        </Border>

        <pop:ConfirmDeletePopup x:Name="DeletePopup" Visibility="Collapsed" 
                         OnConfirm="DeletePopup_OnConfirm" />
    </Grid>
</UserControl>