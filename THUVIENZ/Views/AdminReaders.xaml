<UserControl x:Class="THUVIENZ.Views.AdminReaders"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:comp="clr-namespace:THUVIENZ.Views.Components"
             xmlns:pop="clr-namespace:THUVIENZ.Views.Popups">

    <UserControl.Resources>
        <Style x:Key="BaseTabButtonStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="#F3F4F6" CornerRadius="12" Padding="20,10" Margin="0,0,15,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#4B5563"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border Background="White" CornerRadius="35"
                HorizontalAlignment="Center" VerticalAlignment="Center" 
                Width="900" Height="620">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Opacity="0.2" ShadowDepth="10" Color="Black"/>
            </Border.Effect>

            <Grid Margin="60,50,60,50">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <StackPanel HorizontalAlignment="Left">
                        <TextBlock Text="Quản lý Độc giả" FontSize="36" FontWeight="Bold" Foreground="#111827"/>
                        <TextBlock Text="Quản lý thông tin, tìm kiếm và vô hiệu hóa tài khoản độc giả" FontSize="16" Foreground="#6B7280" Margin="0,5,0,0"/>
                    </StackPanel>

                    <Button Content="{Binding PendingRequestCount, StringFormat='🔔 Xem Yêu cầu ({0})'}" HorizontalAlignment="Right" VerticalAlignment="Center" 
                            Width="160" Height="45" Background="#F59E0B" Foreground="White" 
                            FontSize="16" FontWeight="Bold" Cursor="Hand" Click="BtnViewRequests_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D97706"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
                    <RadioButton Content="🟢 Hoạt động" Tag="#10B981" Style="{StaticResource BaseTabButtonStyle}" IsChecked="True" Click="TabActive_Click"/>
                    <RadioButton Content="🟡 Đình chỉ" Tag="#F59E0B" Style="{StaticResource BaseTabButtonStyle}" Click="TabLocked_Click"/>
                    <RadioButton Content="🔴 Vô hiệu hóa" Tag="#EF4444" Style="{StaticResource BaseTabButtonStyle}" Click="TabDisActive_Click"/>
                </StackPanel>

                <comp:SearchBar Grid.Row="2" SearchText="{Binding SearchKeyword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20"/>

                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" BorderThickness="0" Margin="0,0,0,20" Padding="0,5,10,5">
                    <ItemsControl ItemsSource="{Binding Readers}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <comp:ReaderCard ReaderName="{Binding HoTen}" ReaderId="{Binding MaDocGia}" 
                                                  Address="{Binding DiaChi}" Gender="{Binding GioiTinh}" 
                                                  Email="{Binding Email}" Phone="{Binding SoDienThoai}" 
                                                  AvatarSource="/Assets/phai.png" 
                                                  DeleteCommand="{Binding DataContext.DeleteReaderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  DeleteCommandParameter="{Binding}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </Grid>
        </Border>

        <pop:ConfirmDeletePopup x:Name="DeletePopup" Visibility="Collapsed" 
                         OnConfirm="DeletePopup_OnConfirm" />
    </Grid>
</UserControl>