<Window x:Class="THUVIENZ.Views.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:THUVIENZ.ViewModels"
        xmlns:uc="clr-namespace:THUVIENZ.UserControls"
        Title="Login System" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI">

    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Window.Background>
        <ImageBrush ImageSource="pack://application:,,,/Assets/Images/Background.jpg" Stretch="UniformToFill"/>
    </Window.Background>

    <Grid>
        <Border Width="1050" Height="620" CornerRadius="35" Background="Transparent">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" Opacity="0.3" ShadowDepth="10" Color="Black"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="400"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="35,0,0,35" Background="#40000000" Grid.ColumnSpan="2" Margin="0,0,325,0">
                    <StackPanel VerticalAlignment="Center" 
                                Margin="20,0,363,0">
                        <Ellipse Width="170" Height="170" Stroke="#EAEAEA" StrokeThickness="4">
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.3"/>
                            </Ellipse.Effect>
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="/Assets/phai.png" Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                        </Ellipse>

                        <TextBlock Text="Chào mừng đến với" FontSize="18" Foreground="#E0E0E0" TextAlignment="Center" Margin="0,30,0,5"/>
                        <TextBlock Text="Librix" FontSize="32" FontWeight="Bold" Foreground="White" TextAlignment="Center"/>
                        <TextBlock Text="Hệ thống Quản lý thư viện" FontSize="24" FontWeight="Bold" Foreground="White" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="0,35,35,0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="420">

                        <Image Source="pack://application:,,,/Assets/Images/Logo.jpg" Width="240"/>
                        <TextBlock Text="ĐĂNG NHẬP" FontSize="30" FontWeight="Bold" Foreground="#000000" HorizontalAlignment="Center" Margin="0,0,0,40"/>

                        <TextBlock Text="ID tài khoản" FontSize="15" FontWeight="SemiBold" Foreground="#555" Margin="15,0,0,8"/>
                        <TextBox x:Name="txtUserID" Text="{Binding Id, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource RoundedPlaceholderTextBox}" Tag="Nhập ID"/>
                        <TextBlock Text="{Binding IdError}" 
                           Foreground="Red" 
                           FontSize="11" 
                           FontStyle="Italic"
                           Margin="0,2,0,10" />

                        <TextBlock Text="Mật khẩu" FontSize="15" FontWeight="SemiBold" Foreground="#555" Margin="15,0,0,8"/>
                        <uc:PasswordInput x:Name="txtPassword" Password="{Binding Password, UpdateSourceTrigger=PropertyChanged}" Placeholder="Nhập mật khẩu"/>
                        <TextBlock Text="{Binding PasswordError}" 
                           Foreground="Red" 
                           FontSize="11" 
                           FontStyle="Italic"
                           Margin="0,2,0,10" />

                        <Grid>
                            <TextBlock FontSize="14" FontWeight="Medium" HorizontalAlignment="Left" Margin="0,5,5,40">
                                <Hyperlink Click="LnkRegister_Click" Foreground="#4285F4" TextDecorations="None">
                                    Đăng ký
                                </Hyperlink>
                            </TextBlock>

                            <TextBlock FontSize="14" FontWeight="Medium" HorizontalAlignment="Right" Margin="0,5,5,40">
                                <Hyperlink Click="LnkForgot_Click" Foreground="#4285F4" TextDecorations="None">
                                    Quên mật khẩu?
                                </Hyperlink>
                            </TextBlock>
                        </Grid>

                        <Button Content="Đăng nhập" Command="{Binding LoginCommand}" Style="{StaticResource PrimaryGreenButton}" Margin="0,0,0,20"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>