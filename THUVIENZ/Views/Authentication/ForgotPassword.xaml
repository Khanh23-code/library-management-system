<Window x:Class="THUVIENZ.Views.ForgotPassword"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:THUVIENZ.ViewModels"
        xmlns:uc="clr-namespace:THUVIENZ.UserControls"
        Title="Forgot Password" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI">

    <Window.DataContext>
        <vm:ForgotPasswordViewModel/>
    </Window.DataContext>

    <Window.Background>
        <ImageBrush ImageSource="pack://application:,,,/Assets/Images/Background.jpg" Stretch="UniformToFill"/>
    </Window.Background>

    <Grid>
        <Border Width="1050" Height="720" CornerRadius="35" Background="Transparent">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" Opacity="0.3" ShadowDepth="10" Color="Black"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="400"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="35,0,0,35" Background="#40000000">
                    <StackPanel VerticalAlignment="Center" Margin="20">
                        <Ellipse Width="150" Height="150" Stroke="#EAEAEA" StrokeThickness="4">
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.3"/>
                            </Ellipse.Effect>
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="pack://application:,,,/Assets/phai.png" Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                        </Ellipse>

                        <TextBlock Text="Đừng lo lắng!" FontSize="18" Foreground="#E0E0E0" TextAlignment="Center" Margin="0,30,0,5"/>
                        <TextBlock Text="Librix" FontSize="32" FontWeight="Bold" Foreground="White" TextAlignment="Center"/>
                        <TextBlock Text="Hỗ trợ khôi phục" FontSize="20" FontWeight="SemiBold" Foreground="White" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="0,35,35,0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="420" Height="700">

                        <Image Source="pack://application:,,,/Assets/Images/Logo.jpg" Width="240" Margin="0,0,0,20"/>
                        <TextBlock Text="TẠO LẠI MẬT KHẨU" FontSize="26" FontWeight="Bold" Foreground="#000000" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                        <TextBlock Text="ID tài khoản" FontSize="14" FontWeight="SemiBold" Foreground="#555" Margin="15,0,0,5"/>
                        <TextBox x:Name="txtUserID" Style="{StaticResource RoundedPlaceholderTextBox}" Text="{Binding Id, UpdateSourceTrigger=PropertyChanged}" Tag="Nhập ID tài khoản của bạn"/>
                        <TextBlock Text="{Binding IdError}" 
                           Foreground="Red" 
                           FontSize="11" 
                           FontStyle="Italic"
                           Margin="0,2,0,10" />

                        <TextBlock Text="Mật khẩu mới" FontSize="14" FontWeight="SemiBold" Foreground="#555" Margin="15,0,0,5"/>
                        <uc:PasswordInput x:Name="txtNewPassword" Placeholder="Nhập mật khẩu mới" Password="{Binding Password, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="{Binding PasswordError}" 
                           Foreground="Red" 
                           FontSize="11" 
                           FontStyle="Italic"
                           Margin="0,2,0,10" />

                        <TextBlock Text="Xác nhận mật khẩu" FontSize="14" FontWeight="SemiBold" Foreground="#555" Margin="15,0,0,5"/>
                        <uc:PasswordInput x:Name="txtConfirmPassword" Placeholder="Nhập lại mật khẩu mới" Margin="0,0,0,10"/>

                        <Button Content="Đổi mật khẩu" Style="{StaticResource PrimaryGreenButton}" Command="{Binding ForgotPasswordCommand}" Width="250" Margin="0,20,0,20"/>

                        <TextBlock HorizontalAlignment="Center" Cursor="Hand" MouseLeftButtonDown="BtnBackToLogin_Click">
                            <Run Text=" Quay lại Đăng nhập" Foreground="#4285F4" FontSize="14" FontWeight="Bold"/>
                        </TextBlock>

                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>