<Window x:Class="THUVIENZ.Views.Notifications"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:THUVIENZ"
        Title="Notifications" Height="900" Width="1400"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="MenuBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="25,15"/>
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30FFFFFF"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Window.Background>
        <ImageBrush ImageSource="/Assets/Images/Background.jpg" Stretch="UniformToFill"/>
    </Window.Background>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <local:NavigationBar Grid.Column="0"/>

        <Border Grid.Column="1" Margin="25" Background="White" CornerRadius="35">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Opacity="0.2" ShadowDepth="10" Color="Black"/>
            </Border.Effect>

            <Grid Margin="50,40,30,40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,20,30">
                    <StackPanel>
                        <TextBlock Text="Thông Báo" FontSize="36" FontWeight="Bold" Foreground="#111827"/>
                        <TextBlock Text="Cập nhật tình trạng sách và tin tức từ thư viện" FontSize="16" Foreground="#6B7280" Margin="0,5,0,0"/>
                    </StackPanel>

                    <Button Content="Đánh dấu tất cả đã đọc" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" Foreground="#4285F4" FontSize="16" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,20,0">
                    <StackPanel>

                        <Border x:Name="AlertNotification" Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="15" Padding="20" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Column="0" Grid.RowSpan="2" Width="45" Height="45" Background="#FEE2E2" CornerRadius="22.5" HorizontalAlignment="Left" VerticalAlignment="Top">
                                    <TextBlock Text="⚠️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <TextBlock Grid.Column="1" Grid.Row="0" Text="Sách sắp đến hạn trả!" FontSize="18" FontWeight="Bold" Foreground="#991B1B" Margin="0,0,15,5"/>

                                <StackPanel Grid.Column="2" Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                    <TextBlock Text="2 giờ trước" FontSize="14" Foreground="#DC2626" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Button Content="✕" Width="24" Height="24" Background="Transparent" Foreground="#F87171" BorderThickness="0" Cursor="Hand" ToolTip="Xóa thông báo">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#FECACA"/>
                                                        <Setter Property="Foreground" Value="#7F1D1D"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>

                                <TextBlock Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1" Text="Cuốn sách 'Cấu trúc dữ liệu và thuật toán' của bạn sẽ hết hạn vào ngày mai. Vui lòng trả sách hoặc gia hạn để tránh bị phạt." FontSize="16" Foreground="#7F1D1D" TextWrapping="Wrap" Margin="0,5,0,0"/>
                            </Grid>
                        </Border>

                        <Border x:Name="InfoNotification" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="15" Padding="20" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Column="0" Grid.RowSpan="2" Width="45" Height="45" Background="#DBEAFE" CornerRadius="22.5" HorizontalAlignment="Left" VerticalAlignment="Top">
                                    <TextBlock Text="📢" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <TextBlock Grid.Column="1" Grid.Row="0" Text="Thư viện nghỉ lễ Quốc Khánh 2/9" FontSize="18" FontWeight="Bold" Foreground="#1E3A8A" Margin="0,0,15,5"/>

                                <StackPanel Grid.Column="2" Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                    <TextBlock Text="Hôm qua" FontSize="14" Foreground="#2563EB" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Button Content="✕" Width="24" Height="24" Background="Transparent" Foreground="#60A5FA" BorderThickness="0" Cursor="Hand" ToolTip="Xóa thông báo">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#BFDBFE"/>
                                                        <Setter Property="Foreground" Value="#1E3A8A"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>

                                <TextBlock Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1" Text="Thư viện Librix sẽ đóng cửa nghỉ lễ từ ngày 01/09 đến hết ngày 04/09. Những sách có hạn trả trong thời gian này sẽ được tự động dời sang ngày 05/09." FontSize="16" Foreground="#1E40AF" TextWrapping="Wrap" Margin="0,5,0,0"/>
                            </Grid>
                        </Border>

                        <Border x:Name="SuccessNotification" Background="#F0FDF4" BorderBrush="#BBF7D0" BorderThickness="1" CornerRadius="15" Padding="20" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Column="0" Grid.RowSpan="2" Width="45" Height="45" Background="#DCFCE7" CornerRadius="22.5" HorizontalAlignment="Left" VerticalAlignment="Top">
                                    <TextBlock Text="✅" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <TextBlock Grid.Column="1" Grid.Row="0" Text="Thanh toán tiền phạt thành công" FontSize="18" FontWeight="Bold" Foreground="#166534" Margin="0,0,15,5"/>

                                <StackPanel Grid.Column="2" Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                    <TextBlock Text="12/03/2026" FontSize="14" Foreground="#16A34A" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Button Content="✕" Width="24" Height="24" Background="Transparent" Foreground="#4ADE80" BorderThickness="0" Cursor="Hand" ToolTip="Xóa thông báo">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#BBF7D0"/>
                                                        <Setter Property="Foreground" Value="#14532D"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>

                                <TextBlock Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1" Text="Bạn đã thanh toán thành công 50.000 VNĐ cho phiếu phạt vi phạm. Cảm ơn bạn đã hoàn tất nghĩa vụ." FontSize="16" Foreground="#15803D" TextWrapping="Wrap" Margin="0,5,0,0"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
