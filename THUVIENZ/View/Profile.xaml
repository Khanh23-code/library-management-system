<Window x:Class="THUVIENZ.Profile"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Profile" Height="900" Width="1400"
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI">

    <Window.Background>
        <ImageBrush ImageSource="pack://application:,,,/Images/bg.jpg" Stretch="UniformToFill"/>
    </Window.Background>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Margin="20" CornerRadius="35" Background="#40FFFFFF">
            <StackPanel Margin="10,30,10,10">
                <TextBlock Text="📚 Librix" FontSize="32" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,50"/>

                <Button Content="👤  Profile" Background="#60FFFFFF" Style="{DynamicResource MenuBtn}"/>
                <Button Content="❤️  Favorites" Click="BtnFavorite_Click" Style="{DynamicResource MenuBtn}"/>
                <Button Content="🔍  Search" Click="BtnSearch_Click" Style="{DynamicResource MenuBtn}"/>
                <Button Content="💰  Tiền phạt" Click="BtnFine_Click" Style="{DynamicResource MenuBtn}"/>
                <Button Content="📜  Quy định" Click="BtnRules_Click" Style="{DynamicResource MenuBtn}"/>

                <Button Content="🚪  Đăng xuất" Click="BtnLogout_Click" Style="{DynamicResource MenuBtn}" Foreground="#FF4C4C" Margin="0,50,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="20,20,40,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="THÔNG TIN CÁ NHÂN" FontSize="32" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                <Ellipse HorizontalAlignment="Right" Width="70" Height="70" Stroke="White" StrokeThickness="2">
                    <Ellipse.Fill>
                        <ImageBrush ImageSource="pack://application:,,,/Images/phai.png" Stretch="UniformToFill"/>
                    </Ellipse.Fill>
                </Ellipse>
            </Grid>

            <Border Grid.Row="1" CornerRadius="35" Background="#30FFFFFF" Padding="50,40">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="User Name:" Foreground="White" FontSize="20" Margin="0,15,0,5"/>
                        <TextBox Text="Nguyễn Văn Reader" Background="Transparent" Foreground="White" FontSize="20" BorderBrush="White" BorderThickness="0,0,0,1"/>
                        <TextBlock Text="Reader ID:" Foreground="White" FontSize="20" Margin="0,15,0,5"/>
                        <TextBox Text="RD-2023" Background="Transparent" Foreground="White" FontSize="20" BorderBrush="White" BorderThickness="0,0,0,1"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Phone:" Foreground="White" FontSize="20" Margin="0,15,0,5"/>
                        <TextBox Text="0909123456" Background="Transparent" Foreground="White" FontSize="20" BorderBrush="White" BorderThickness="0,0,0,1"/>
                        <TextBlock Text="Address:" Foreground="White" FontSize="20" Margin="0,15,0,5"/>
                        <TextBox Text="Bình Dương" Background="Transparent" Foreground="White" FontSize="20" BorderBrush="White" BorderThickness="0,0,0,1"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>

    <Window.Resources>
        <Style x:Key="MenuBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#50FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
</Window>