<Window x:Class="THUVIENZ.Fine"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fine" Height="900" Width="1400"
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI">

    <Window.Background>
        <ImageBrush ImageSource="pack://application:,,,/Images/bg.jpg" Stretch="UniformToFill"/>
    </Window.Background>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Margin="20" CornerRadius="35" Background="#40FFFFFF">
            <StackPanel Margin="10,30,10,10">
                <TextBlock Text="📚 Librix" FontSize="32" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,50"/>

                <Button Content="👤  Profile" Click="BtnProfile_Click" Style="{DynamicResource MenuBtn}"/>
                <Button Content="❤️  Favorites" Click="BtnFavorite_Click" Style="{DynamicResource MenuBtn}"/>
                <Button Content="🔍  Search" Click="BtnSearch_Click" Style="{DynamicResource MenuBtn}"/>
                <Button Content="💰  Tiền phạt" Background="#60FFFFFF" Style="{DynamicResource MenuBtn}"/>
                <Button Content="📜  Quy định" Click="BtnRules_Click" Style="{DynamicResource MenuBtn}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="20,20,40,20">
            <StackPanel>
                <TextBlock Text="PHIẾU THU TIỀN PHẠT" FontSize="32" FontWeight="Bold" Foreground="White" Margin="0,0,0,20"/>

                <Border Background="#30FFFFFF" CornerRadius="20" Height="400" Padding="40">
                    <StackPanel>
                        <TextBlock Text="Sách quá hạn: Cấu trúc dữ liệu và thuật toán" FontSize="22" Foreground="White" Margin="0,0,0,10"/>
                        <TextBlock Text="Số ngày trễ: 5 ngày" FontSize="22" Foreground="White" Margin="0,0,0,10"/>
                        <TextBlock Text="Tổng tiền phạt: 50.000 VNĐ" FontSize="26" FontWeight="Bold" Foreground="#FF4C4C" Margin="0,20,0,30"/>

                        <Button Content="Thanh toán ngay" Width="200" Height="50" Background="#0CE346" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Left">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="25"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>

    <Window.Resources>
        <Style x:Key="MenuBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
</Window>