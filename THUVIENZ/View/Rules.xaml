<Window x:Class="THUVIENZ.Rules"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rules" Height="900" Width="1400"
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI">

    <Window.Background>
        <ImageBrush ImageSource="pack://application:,,,/Images/bg.jpg" Stretch="UniformToFill"/>
    </Window.Background>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Margin="20" CornerRadius="35" Background="#40FFFFFF">
            <StackPanel Margin="10,30,10,10">
                <TextBlock Text="📚 Librix" FontSize="32" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,50"/>

                <Button Content="👤  Profile" Click="BtnProfile_Click" Style="{DynamicResource MenuBtn}"/>
                <Button Content="❤️  Favorites" Click="BtnFavorite_Click" Style="{DynamicResource MenuBtn}"/>
                <Button Content="🔍  Search" Click="BtnSearch_Click" Style="{DynamicResource MenuBtn}"/>
                <Button Content="💰  Tiền phạt" Click="BtnFine_Click" Style="{DynamicResource MenuBtn}"/>
                <Button Content="📜  Quy định" Background="#60FFFFFF" Style="{DynamicResource MenuBtn}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="20,20,40,20">
            <StackPanel>
                <TextBlock Text="QUY ĐỊNH THƯ VIỆN" FontSize="32" FontWeight="Bold" Foreground="White" Margin="0,0,0,20"/>

                <Border Background="#30FFFFFF" CornerRadius="20" Height="500" Padding="30">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="1. Độc giả được mượn tối đa 3 quyển sách cùng lúc." FontSize="20" Foreground="White" Margin="0,0,0,15" TextWrapping="Wrap"/>
                            <TextBlock Text="2. Thời hạn mượn sách là 14 ngày kể từ ngày lập phiếu." FontSize="20" Foreground="White" Margin="0,0,0,15" TextWrapping="Wrap"/>
                            <TextBlock Text="3. Phạt 10.000 VNĐ cho mỗi ngày trễ hạn trả sách." FontSize="20" Foreground="White" Margin="0,0,0,15" TextWrapping="Wrap"/>
                            <TextBlock Text="4. Giữ gìn sách cẩn thận, không viết hay vẽ bậy lên sách." FontSize="20" Foreground="White" Margin="0,0,0,15" TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>

    <Window.Resources>
        <Style x:Key="MenuBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
</Window>